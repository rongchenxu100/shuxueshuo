# 微信公众平台（服务号）开发者凭据
WECHAT_MP_APP_ID=wxxxxxxxxxxxxxxxx
WECHAT_MP_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 站点对外 HTTPS 来源（无尾部斜杠），须与浏览器地址栏一致；签名接口只接受以此开头的 url
PUBLIC_SITE_ORIGIN=https://www.example.com

# Method Solver runtime
SOLVER_PLANNER_MODE=deterministic
SOLVER_LLM_PROVIDER=deepseek

# DeepSeek OpenAI-compatible API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Doubao Ark OpenAI-compatible API
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-1-6
