  },
  "steps": [
    {
      "id": "i1s1",
      "section": "第（Ⅰ）①问",
      "title": "第1步：代入 A 与 D 求解析式",
      "t": 0.75,
      "derive": [
        ["∵", "C(0,−3)，C 水平右移 2 个单位得到 D"],
        ["∴", "D(2,−3)"],
        ["∵", "A(−1,0) 在 y＝ax²＋bx－3 上"],
        ["∴", "a−b−3＝0，即 b＝a−3"],
        ["∵", "D(2,−3) 在抛物线上"],
        ["∴", "4a＋2b−3＝−3"],
        ["∴", "4a＋2b＝0，即 b＝−2a"],
        ["∴", "a＝1，b＝−2"],
        ["∴", "y＝x²－2x－3"]
      ],
      "box": ["a＝1，b＝−2", "y＝x²－2x－3"]
    },
    {
      "id": "i1s2",
      "section": "第（Ⅰ）②问",
      "title": "第1步：由∠CBE＋∠ACO＝45°，转换为∠OBE＝∠ACO，求与OC交点 F",
      "t": 0.75,
      "derive": [
        ["∵", "由第（Ⅰ）①可得 B(3,0)，C(0,−3)"],
        ["∵", "AO＝1，CO＝3"],
        ["∴", "tan∠ACO＝1/3"],
        ["作", "BE 交 OC 于点 F"],
        ["∵", "△BOC 是等腰直角三角形"],
        ["∴", "∠OBC＝45°"],
        ["∵", "∠CBE＋∠ACO＝45°"],
        ["∴", "∠OBF＝∠ACO"],
        ["∵", "△BOF 是直角三角形，OB＝3"],
        ["∴", "tan∠OBF＝OF/OB＝1/3"],
        ["∴", "OF＝1，F(0,−1)"]
      ],
      "box": ["F(0, −1)"]
    },
    {
      "id": "i1s3",
      "section": "第（Ⅰ）②问",
      "title": "第2步：联立 BF 与抛物线求 E",
      "t": 0.75,
      "derive": [
        ["∵", "直线 BF 过 B(3,0)、F(0,−1)"],
        ["∴", "BF：y＝x/3−1"],
        ["∵", "E 是 BF 与抛物线 y＝x²−2x−3 的另一个交点"],
        ["∴", "x²−2x−3＝x/3−1"],
        ["∴", "3x²−7x−6＝0"],
        ["∴", "(x−3)(3x＋2)＝0"],
        ["∵", "x＝3 对应点 B，且 −1＜m＜0"],
        ["∴", "m＝−2/3"],
        ["∴", "y＝−2/9−1＝−11/9"],
        ["∴", "E(−2/3,−11/9)"]
      ],
      "box": ["BF：y＝x/3−1", "E(−2/3, −11/9)"]
    },
    {
      "id": "q1s1",
      "section": "第（Ⅱ）问",
      "title": "第1步：用 a 表示点 B",
      "t": 0.75,
      "derive": [
        ["∵", "A(−1,0) 与 B 是抛物线的两个 x 轴交点"],
        ["∴", "两根为 −1 与 3/a"],
        ["∴", "B(3/a,0)"],
        ["∴", "CB＝√[(3/a)²＋3²]＝3√(1＋a²)/a"]
      ],
      "box": ["B(3/a,0)", "CB＝3√(1＋a²)/a"]
    },
    {
      "id": "q1s2",
      "section": "第（Ⅱ）问",
      "title": "第2步：构造全等三角形，把两动点问题转化为单动点问题",
      "t": 0.75,
      "derive": [
        ["作", "在射线 CD 上取点 G，使 CG＝CB"],
        ["∵", "N 在射线 CD 上，M 在线段 BC 上"],
        ["∴", "∠BCN＝∠GCM"],
        ["∵", "CN＝CM"],
        ["∵", "CB＝CG"],
        ["∴", "△CBN≌△GCM"],
        ["∴", "BN＝MG"],
        ["∴", "OM＋BN＝OM＋MG"]
      ],
      "box": ["BN＝MG", "OM＋BN＝OM＋MG"],
      "localControls": {
        "values": { "u": 0.555556 },
        "note": "拖动 M，N 会按 CN＝CM 联动，观察 BN 与 MG 始终相等。",
        "controls": [
          { "var": "u", "label": "动点 M：CM/CB", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 },
          { "var": "u", "label": "动点 N：CN/CG", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 }
        ]
      }
    },
    {
      "id": "q1s3",
      "section": "第（Ⅱ）问",
      "title": "第3步：用将军饮马确定最小值位置",
      "t": 0.75,
      "derive": [
        ["∵", "OM＋BN＝OM＋MG"],
        ["∵", "O 与 G 分别在直线 BC 的两侧"],
        ["∵", "两点之间线段最短"],
        ["∴", "OM＋MG≥OG"],
        ["∴", "当 O、M、G 三点共线时，OM＋BN 取得最小值"]
      ],
      "box": ["最小值为 OG"],
      "localControls": {
        "values": { "u": 0.555556 },
        "note": "拖动 M 观察：O、M、G 三点共线时路径最短。",
        "controls": [
          { "var": "u", "label": "动点 M：CM/CB", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 }
        ]
      }
    },
    {
      "id": "q1s4",
      "section": "第（Ⅱ）问",
      "title": "第4步：计算最小值并求 a",
      "t": 0.75,
      "derive": [
        ["∵", "CO＝3，CB＝3√(1＋a²)/a"],
        ["∵", "CG＝CB，且 OG 是直角三角形 OCG 的斜边"],
        ["∴", "OG²＝OC²＋CG²"],
        ["∴", "OG²＝9＋[3√(1＋a²)/a]²"],
        ["∴", "最小值²＝18＋9/a²"],
        ["∵", "OM＋BN 的最小值为 √34"],
        ["∴", "18＋9/a²＝34"],
        ["∴", "9/a²＝16"],
        ["∵", "a＞0"],
        ["∴", "a＝3/4"]
      ],
      "box": ["最小值＝√(18＋9/a²)", "a＝3/4"]
    }
  ],
