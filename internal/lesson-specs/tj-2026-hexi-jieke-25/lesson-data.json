  "steps": [
    {
      "id": "i1s1",
      "section": "第（Ⅰ）问",
      "title": "第1步：由 A 点求解析式并读出顶点 P",
      "t": 0.5,
      "derive": [
        ["∵", "A(−1,0) 在 y＝ax²＋bx＋c 上"],
        ["∴", "a−b＋c＝0"],
        ["∵", "b＝−2，c＝−3"],
        ["∴", "a−(−2)−3＝0"],
        ["∴", "a＝1"],
        ["∵", "y＝x²−2x−3"],
        ["∴", "y＝(x−1)²−4"],
        ["∴", "顶点 P(1,−4)"]
      ],
      "box": ["y＝x²−2x−3", "P(1,−4)"]
    },
    {
      "id": "q0s1",
      "section": "第（Ⅱ）公共结论",
      "title": "第1步：化简函数表达式",
      "t": 0.5,
      "derive": [
        ["∵", "2a＋b＝0"],
        ["∴", "b＝−2a"],
        ["∵", "A(−1,0) 在抛物线上"],
        ["∴", "a−b＋c＝0"],
        ["∴", "a−(−2a)＋c＝0"],
        ["∴", "c＝−3a"],
        ["∵", "y＝ax²−2ax−3a"],
        ["∴", "y＝a(x＋1)(x−3)"],
        ["∴", "B(3,0)"],
        ["∴", "对称轴为 x＝1，顶点 P(1,−4a)"]
      ],
      "box": ["y＝a(x＋1)(x−3)", "B(3,0)", "P(1,−4a)"]
    },
    {
      "id": "q1s1",
      "section": "第（Ⅱ）①问",
      "title": "第1步：由 MP＝MA 求 a",
      "t": 0.5,
      "derive": [
        ["∵", "M(a,a−1)，P(1,−4a)，A(−1,0)"],
        ["∴", "MP²＝(a−1)²＋(5a−1)²"],
        ["∴", "MA²＝(a＋1)²＋(a−1)²"],
        ["∵", "MP＝MA"],
        ["∴", "(5a−1)²＝(a＋1)²"],
        ["∴", "5a−1＝a＋1，或 5a−1＝−(a＋1)"],
        ["∴", "a＝1/2，或 a＝0"],
        ["∵", "a＞0"],
        ["∴", "a＝1/2"]
      ],
      "box": ["第（Ⅱ）①问：a＝1/2"]
    },
    {
      "id": "q2s1",
      "section": "第（Ⅱ）②问",
      "title": "第1步：构造等腰三角形得到∠NAB半角",
      "t": 0.5,
      "derive": [
        ["∵", "A(−1,0)，N(0,−4/3)"],
        ["∴", "AN＝√[1²＋(4/3)²]＝5/3"],
        ["作", "在 x 轴 A 点左侧取 E，使 EA＝AN＝5/3"],
        ["∵", "EA＝AN"],
        ["∴", "△EAN 是等腰三角形"],
        ["∵", "∠NAO 是 △EAN 的外角"],
        ["∴", "∠NAO＝2∠AEN"],
        ["∵", "射线 AO 与射线 AB 同方向"],
        ["∴", "∠NAO＝∠NAB"],
        ["∴", "∠AEN＝1/2∠NAB"],
        ["∵", "EO＝8/3，ON＝4/3"],
        ["∴", "tan∠AEN＝ON/EO＝1/2"]
      ],
      "box": ["tan∠AEN＝1/2"]
    },
    {
      "id": "q2s2",
      "section": "第（Ⅱ）②问",
      "title": "第2步：由 tan∠ABC 求 a",
      "t": 0.5,
      "derive": [
        ["∵", "B(3,0)，C(0,−3a)"],
        ["∴", "在直角三角形 BOC 中，BO＝3，CO＝3a"],
        ["∴", "tan∠ABC＝CO/BO＝a"],
        ["∵", "∠NAB＝2∠ABC"],
        ["∵", "∠NAB＝2∠AEN"],
        ["∴", "∠ABC＝∠AEN"],
        ["∴", "tan∠ABC＝tan∠AEN＝1/2"],
        ["∴", "a＝1/2"]
      ],
      "box": ["第（Ⅱ）②问：a＝1/2"]
    }
  ],
