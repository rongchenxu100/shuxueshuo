  "steps": [
    {
      "id": "i1s1",
      "section": "第（1）问",
      "title": "第1步：代入并配方求顶点 P",
      "t": 3,
      "derive": [
        ["∵", "b＝2，c＝3"],
        ["∴", "y＝−x²＋2x＋3"],
        ["∴", "y＝−(x−1)²＋4"],
        ["∴", "P(1,4)"]
      ],
      "box": ["y＝−(x−1)²＋4", "P(1,4)"]
    },
    {
      "id": "q1s1",
      "section": "第（2）①问",
      "title": "第1步：化简函数表达式",
      "t": 3,
      "derive": [
        ["∵", "A(−1,0) 在 y＝−x²＋bx＋c 上"],
        ["∴", "0＝−1−b＋c"],
        ["∴", "c＝b＋1"],
        ["∴", "y＝−x²＋bx＋b＋1"],
        ["∴", "y＝−(x＋1)(x−b−1)"],
        ["∵", "A、B 是 x 轴交点，且 A 在 B 左侧"],
        ["∴", "B(b＋1,0)"],
        ["∵", "C 是 y 轴交点"],
        ["∴", "C(0,b＋1)"]
      ],
      "box": ["B(b＋1,0)", "C(0,b＋1)"]
    },
    {
      "id": "q1s2",
      "section": "第（2）①问",
      "title": "第2步：由两点间距离公式求解 b",
      "t": 3,
      "derive": [
        ["∵", "A(−1,0)，B(b＋1,0)"],
        ["∴", "AB＝b＋2"],
        ["∵", "B(b＋1,0)，C(0,b＋1)"],
        ["∴", "BC＝√[(b＋1)²＋(b＋1)²]＝√2(b＋1)"],
        ["∵", "BC＝AB"],
        ["∴", "√2(b＋1)＝b＋2"],
        ["∴", "b＝√2"]
      ],
      "box": ["b＝√2"]
    },
    {
      "id": "q2s1",
      "section": "第（2）②问",
      "title": "第1步：平移线段构建将军饮马模型",
      "t": 10,
      "derive": [
        ["∵", "D(b−2,yD) 在抛物线上"],
        ["∴", "yD＝−(b−2)²＋b(b−2)＋b＋1＝3b−3"],
        ["∴", "D(b−2,3b−3)"],
        ["∵", "对称轴为 x＝b/2"],
        ["∴", "F 的横坐标为 b/2"],
        ["作", "把 D 向左平移 b/2 个单位，得到 D′(b/2−2,3b−3)"],
        ["∴", "DF＝ED′"],
        ["∴", "BE＋DF＝BE＋ED′"]
      ],
      "box": ["D′(b/2−2,3b−3)", "BE＋DF＝BE＋ED′"]
    },
    {
      "id": "q2s2",
      "section": "第（2）②问",
      "title": "第2步：将军饮马得到最短线段",
      "t": 11.49,
      "derive": [
        ["作", "B 关于 y 轴的对称点 B′"],
        ["∵", "B(b＋1,0)"],
        ["∴", "B′(−b−1,0)"],
        ["∵", "E 在 y 轴上"],
        ["∴", "BE＝B′E"],
        ["∴", "BE＋DF＝B′E＋ED′"],
        ["∵", "两点之间线段最短"],
        ["∴", "B′E＋ED′≥B′D′"],
        ["∴", "最小值为 B′D′"]
      ],
      "box": ["最小值：B′D′"]
    },
    {
      "id": "q2s3",
      "section": "第（2）②问",
      "title": "第3步：由 B′D′=√205 求 b",
      "t": 11.49,
      "derive": [
        ["∵", "B′(−b−1,0)，D′(b/2−2,3b−3)"],
        ["∴", "B′D′²＝(b/2−2+b+1)²＋(3b−3)²"],
        ["∴", "B′D′²＝(3b/2−1)²＋9(b−1)²"],
        ["∵", "BE＋DF 的最小值为 √205"],
        ["∴", "(3b/2−1)²＋9(b−1)²＝205"],
        ["∴", "15b²−28b−260＝0"],
        ["∴", "b＝26/5 或 b＝−10/3"],
        ["∵", "D 在 x 轴上方且在对称轴右侧"],
        ["∴", "b＞4"],
        ["∴", "b＝26/5"]
      ],
      "box": ["b＝26/5"]
    }
  ],
