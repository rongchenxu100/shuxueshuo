  "steps": [
    {
      "id": "i1s1",
      "section": "第（Ⅰ）问",
      "title": "第1步：由系数关系求顶点",
      "t": 0,
      "derive": [
        ["∵", "2a−b=0"],
        ["∴", "b=2a"],
        ["∵", "b=2"],
        ["∴", "a=1"],
        ["∵", "c=3"],
        ["∴", "y=x²+2x+3"],
        ["∴", "y=(x+1)²+2"],
        ["∴", "D(−1,2)"]
      ],
      "box": ["D(−1,2)"]
    },
    {
      "id": "q0s1",
      "section": "第（Ⅱ）公共结论",
      "title": "第1步：由点 P 化简解析式",
      "t": 0,
      "derive": [
        ["∵", "2a−b=0"],
        ["∴", "b=2a"],
        ["∵", "P(3,3) 在抛物线上"],
        ["∴", "9a+3b+c=3"],
        ["∴", "15a+c=3"],
        ["∴", "c=3−15a"],
        ["∴", "y=ax²+2ax+3−15a"],
        ["∴", "y=a(x+1)²+3−16a"]
      ],
      "box": ["b=2a", "c=3−15a", "y=a(x+1)²+3−16a"]
    },
    {
      "id": "q0s2",
      "section": "第（Ⅱ）公共结论",
      "title": "第2步：表示 I 与 NI",
      "t": 0,
      "derive": [
        ["∵", "N(2,3)，I 在直线 x=2 上"],
        ["∴", "yI=4a+4a+3−15a=3−7a"],
        ["∵", "a>0"],
        ["∴", "I(2,3−7a)，NI=7a"]
      ],
      "box": ["I(2,3−7a)", "NI=7a"]
    },
    {
      "id": "q1s1",
      "section": "第（Ⅱ）①问",
      "title": "第1步：由 MP=2NI 求解析式",
      "t": 0,
      "derive": [
        ["∵", "M(3,5)，P(3,3)"],
        ["∴", "MP=2"],
        ["∵", "MP=2NI"],
        ["∴", "2=2NI"],
        ["∴", "NI=1"],
        ["∵", "NI=7a", { "refStep": "q0s2", "refLabel": "回看表示 NI" }],
        ["∴", "a=1/7"],
        ["∴", "b=2/7，c=6/7"],
        ["∴", "y=1/7x²+2/7x+6/7"],
        ["∴", "I(2,3−7a)=I(2,2)"]
      ],
      "box": ["I(2,2)", "y=1/7x²+2/7x+6/7"]
    },
    {
      "id": "q2s1",
      "section": "第（Ⅱ）②问",
      "title": "第1步：代入 H 坐标求 a",
      "t": 0,
      "derive": [
        ["∵", "NI=7a", { "refStep": "q0s2", "refLabel": "回看表示 NI" }],
        ["∵", "15NI−7MH=7"],
        ["∴", "15·7a−7MH=7"],
        ["∴", "MH=15a−1"],
        ["∵", "M(3,5)，H 在 M 右侧的水平线上"],
        ["∴", "H(15a+2,5)"],
        ["∵", "H 在 y=ax²+2ax+3−15a 上"],
        ["∴", "5=a(15a+2)²+2a(15a+2)+3−15a"],
        ["∴", "a(15a+2)²+2a(15a+2)−15a−2=0"],
        ["∵", "−15a−2=−(15a+2)"],
        ["∴", "(15a+2)[a(15a+2)+2a−1]=0"],
        ["∴", "(15a+2)(15a²+4a−1)=0"],
        ["∵", "a>0"],
        ["∴", "15a+2>0"],
        ["∴", "15a²+4a−1=0"],
        ["∴", "a=(-2±√19)/15"],
        ["∵", "a>0"],
        ["∴", "a=(√19−2)/15"]
      ],
      "box": ["(15a+2)(15a²+4a−1)=0", "a=(√19−2)/15"]
    }
  ],
