  "steps": [
    {
      "id": "q1s1",
      "section": "第（1）问",
      "title": "第1步：由已知根写 C₁ 与顶点 M",
      "t": 0,
      "derive": [
        ["∵", "C₁：y＝x²＋bx＋c 经过 A(−1,0)、B(3,0)"],
        ["∴", "1−b＋c＝0 且 9＋3b＋c＝0"],
        ["∴", "b＝−2，c＝−3"],
        ["∴", "C₁：y＝x²−2x−3＝(x−1)²−4"],
        ["∴", "顶点 M(1,−4)"]
      ],
      "box": ["C₁: y＝(x−1)²−4", "M(1,−4)"]
    },
    {
      "id": "q1s2",
      "section": "第（1）问",
      "title": "第2步：作 MC⊥x 轴识别直角三角形",
      "t": 0,
      "derive": [
        ["作", "MC⊥x 轴于 C"],
        ["∴", "∠ACM＝90°"],
        ["∵", "M(1,−4)，A(−1,0)，C(1,0)"],
        ["∴", "AC＝2，MC＝4"],
        ["∴", "△AMC 是直角三角形，∠MAC＋∠AMC＝90°"]
      ],
      "box": ["AC＝2，MC＝4", "∠ACM＝90°"]
    },
    {
      "id": "q1s3",
      "section": "第（1）问",
      "title": "第3步：相似定 N(1,1)",
      "t": 0,
      "derive": [
        ["设", "直线 l 与 MC 延长线交于点 N，N 在 x 轴上方"],
        ["∵", "l⊥AM，即 ∠NAM＝90°"],
        ["∴", "∠NAC＋∠MAC＝90°"],
        ["∵", "∠MAC＋∠AMC＝90°"],
        ["∴", "∠NAC＝∠AMC"],
        ["又", "∠ACN＝∠MCA＝90°"],
        ["∴", "△NAC∽△AMC"],
        ["∴", "NC/AC＝AC/MC，即 NC/2＝2/4"],
        ["∴", "NC＝1，N(1,1)"]
      ],
      "box": ["△NAC∽△AMC", "N(1,1)"]
    },
    {
      "id": "q1s4",
      "section": "第（1）问",
      "title": "第4步：由两点写直线 l",
      "t": 0,
      "derive": [
        ["设", "l：y＝kx＋t（k≠0）"],
        ["∵", "l 经过 A(−1,0) 与 N(1,1)"],
        ["∴", "−k＋t＝0 且 k＋t＝1"],
        ["∴", "k＝½，t＝½"],
        ["∴", "l：y＝½x＋½"]
      ],
      "box": ["l：y＝½x＋½"]
    },
    {
      "id": "q2s1",
      "section": "第（2）问",
      "title": "第1步：由已知根写 C₂ 与 N(1,−4a)",
      "t": 0,
      "derive": [
        ["∵", "C₂：y＝ax²＋mx＋n 开口向下"],
        ["∴", "a＜0"],
        ["∵", "C₂ 经过 A(−1,0)、B(3,0)"],
        ["∴", "a−m＋n＝0 且 9a＋3m＋n＝0"],
        ["∴", "m＝−2a，n＝−3a"],
        ["∴", "C₂：y＝ax²−2ax−3a＝a(x−1)²−4a"],
        ["∴", "顶点 N(1,−4a)"]
      ],
      "box": ["C₂: y＝a(x−1)²−4a", "N(1,−4a)"]
    },
    {
      "id": "q2s2",
      "section": "第（2）问",
      "title": "第2步：用根与系数的关系求 D（已知一根 → 求另一根）",
      "t": 0,
      "derive": [
        ["联立", "y＝½x＋½ 与 y＝ax²−2ax−3a"],
        ["∴", "ax²−2ax−3a＝½x＋½"],
        ["两边×2 并移项", "2ax²−(4a＋1)x−(6a＋1)＝0"],
        ["对比标准式", "形如 Ax²＋Bx＋C＝0，其中 A＝2a，B＝−(4a＋1)，C＝−(6a＋1)"],
        ["由一元二次方程根与系数的关系（即韦达定理）", "x₁·x₂＝C/A＝−(6a＋1)/(2a)"],
        ["∵", "A(−1,0) 是 l 与 C₂ 的公共交点"],
        ["∴", "x₁＝−1 是上式的一个根"],
        ["∴", "(−1)·x₂＝−(6a＋1)/(2a)"],
        ["∴", "x₂＝(6a＋1)/(2a)＝3＋1/(2a)"],
        ["代入直线 l", "y₂＝½·(3＋1/(2a))＋½"],
        ["∴", "y₂＝3/2＋1/(4a)＋1/2＝2＋1/(4a)"],
        ["∴", "D(3＋1/(2a), 2＋1/(4a))"]
      ],
      "box": ["根与系数的关系（俗称韦达定理）：x₁·x₂＝C/A", "由 x₁＝−1（已知 A 是公共点）→ x₂＝3＋1/(2a)", "D(3＋1/(2a), 2＋1/(4a))"]
    },
    {
      "id": "q2s3",
      "section": "第（2）问",
      "title": "第3步：梯形条件分两种情形",
      "t": 0,
      "derive": [
        ["∵", "ANDM 是梯形（恰一组对边平行）"],
        ["∴", "AN∥DM 或 ND∥AM"],
        ["注", "需排除两组对边都平行（即 ANDM 退化为平行四边形）的情况"]
      ],
      "box": ["情形①：AN∥DM", "情形②：ND∥AM"]
    },
    {
      "id": "q2s4",
      "section": "第（2）问",
      "title": "情形①：AN∥DM，相似求 a",
      "t": 0,
      "derive": [
        ["作", "NC⊥x 轴于 C；过 M 作平行 x 轴的线，过 D 作 DE⊥ME 于 E"],
        ["∴", "∠ACN＝∠DEM＝90°"],
        ["∵", "AN∥DM"],
        ["∴", "∠NAC＝∠DME"],
        ["∴", "△NAC∽△DME"],
        ["∴", "AC/NC＝ME/DE"],
        ["∵", "AC＝2，NC＝−4a（a＜0），ME＝(4a＋1)/(2a)，DE＝(24a＋1)/(4a)"],
        ["∴", "2/(−4a)＝[(4a＋1)/(2a)] / [(24a＋1)/(4a)]"],
        ["∴", "8a²＋14a−1＝0"],
        ["∴", "a₁＝(−7−3√5)/8，a₂＝(−7＋3√5)/8"],
        ["∵", "a₂ 时 ANDM 不构成梯形（舍）"],
        ["∴", "a＝(−7−3√5)/8"],
        ["∴", "C₂：y＝[(−7−3√5)/8]·(x²−2x−3)"]
      ],
      "box": ["8a²＋14a−1＝0", "a＝(−7−3√5)/8", "C₂：y＝[(−7−3√5)/8]·(x²−2x−3)"]
    },
    {
      "id": "q2s5",
      "section": "第（2）问",
      "title": "情形②：ND∥AM，相似求 a",
      "t": 0,
      "derive": [
        ["作", "MG⊥x 轴于 G；过 D 作平行 x 轴的线，过 N 作 NH⊥DH 于 H"],
        ["∴", "∠MGA＝∠NHD＝90°"],
        ["∵", "ND∥AM"],
        ["∴", "∠NDH＝∠MAG"],
        ["∴", "△NHD∽△MGA"],
        ["∴", "NH/MG＝HD/GA"],
        ["∵", "AG＝2，MG＝4，NH＝−(16a²＋8a＋1)/(4a)，HD＝(4a＋1)/(2a)"],
        ["∴", "[−(16a²＋8a＋1)/(4a)] / 4 ＝ [(4a＋1)/(2a)] / 2"],
        ["∴", "16a²＋24a＋5＝0"],
        ["∴", "a₁＝−5/4，a₂＝−1/4"],
        ["∵", "a₂ 时 ND 与 AM 等长共线方向，ANDM 退化为平行四边形（舍）"],
        ["∴", "a＝−5/4"],
        ["∴", "C₂：y＝−5/4·(x²−2x−3)"]
      ],
      "box": ["16a²＋24a＋5＝0", "a＝−5/4", "C₂：y＝−5/4·(x²−2x−3)"]
    },
    {
      "id": "q2s6",
      "section": "第（2）问",
      "title": "结论：两条 C₂ 同屏比较",
      "t": 0,
      "derive": [
        ["综上", "梯形 ANDM 对应两组解"],
        ["情形①", "C₂：y＝[(−7−3√5)/8]·(x²−2x−3)"],
        ["情形②", "C₂：y＝−5/4·(x²−2x−3)"]
      ],
      "box": ["C₂ 两解同时存在", "学生需根据 AN∥DM 或 ND∥AM 选择对应情形"]
    }
  ],
