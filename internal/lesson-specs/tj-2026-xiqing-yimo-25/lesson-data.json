    "pageDescription": "2026 天津市西青区一模第 25 题：由定点 A 求 c=b+1，配方求顶点；再由 D 的坐标通式比较 AD 与 BC，最后作 30° 辅助线转化 2DM+AM 的最小值并确定 b。",
    "breadcrumbTitle": "2026 天津市西青区一模 第 25 题"
  },
  "problem": {
    "summary": "第 25 题（2026 天津市西青区一模）二次函数综合：顶点、线段关系与 2DM+AM 最值。",
    "lines": [
      { "text": "25．已知抛物线 y＝−x²＋bx＋c（b，c 为常数，b＞0）经过点 A(−1,0)，与 x 轴交于点 B，与 y 轴交于点 C。" },
      { "text": "（1）当 b＝4 时，求抛物线的顶点坐标；", "answerId": "answerI", "answer": "顶点坐标为 (2,9)" },
      { "text": "（2）点 D(b＋2,yD) 是抛物线上任意一点。" },
      { "text": "① 当 AD＝2BC 时，求 b 的值；", "answerId": "answerII1", "answer": "b＝1" },
      { "text": "② 若点 M(m,0) 是 x 轴正半轴上的动点，当 2DM＋AM 的最小值为 5＋5√3 时，求 b 的值。", "answerId": "answerII2", "answer": "b＝2" }
    ]
  },
  "ui": {
    "legend": [
      { "colorVar": "paper", "label": "第（1）问抛物线  y＝−x²＋4x＋5" },
      { "colorVar": "fold", "label": "第（2）问线段关系与最值" }
    ],
    "sliderLabel": "动点 M 的横坐标 m",
    "paramLabelPrefix": "m=",
    "goToProblemMode": "doubleScroll",
    "groupTitles": {
      "第（1）问": "第（1）问  求顶点坐标",
      "第（2）①问": "第（2）①  由 AD=2BC 求 b",
      "第（2）②问": "第（2）②  由最小值求 b"
    }
  },
  "steps": [
    {
      "id": "i1s1",
      "section": "第（1）问",
      "title": "第1步：由 A 求出 c，再代入 b=4",
      "t": 2.5,
      "derive": [
        ["∵", "A(−1,0) 在 y＝−x²＋bx＋c 上"],
        ["∴", "0＝−1−b＋c"],
        ["∴", "c＝b＋1"],
        ["∵", "b＝4"],
        ["∴", "c＝5"],
        ["∴", "抛物线为 y＝−x²＋4x＋5"]
      ],
      "box": ["c＝b＋1", "y＝−x²＋4x＋5"]
    },
    {
      "id": "i1s2",
      "section": "第（1）问",
      "title": "第2步：配方读出顶点",
      "t": 2.5,
      "derive": [
        ["∵", "y＝−x²＋4x＋5"],
        ["∴", "y＝−(x−2)²＋9"],
        ["∴", "顶点坐标为 (2,9)"]
      ],
      "box": ["顶点坐标：(2,9)"]
    },
    {
      "id": "q1s1",
      "section": "第（2）①问",
      "title": "第1步：写出 B、C、D 的坐标",
      "t": 2.5,
      "derive": [
        ["∵", "A(−1,0) 在抛物线上"],
        ["∴", "c＝b＋1"],
        ["∴", "抛物线为 y＝−x²＋bx＋b＋1"],
        ["∵", "与 x 轴交于 A(−1,0)、B"],
        ["∴", "B(b＋1,0)"],
        ["∵", "与 y 轴交于 C"],
        ["∴", "C(0,b＋1)"],
        ["∵", "D 的横坐标为 b＋2"],
        ["∴", "yD＝−(b＋2)²＋b(b＋2)＋b＋1＝−b−3"],
        ["∴", "D(b＋2,−b−3)"]
      ],
      "box": ["B(b＋1,0)", "C(0,b＋1)", "D(b＋2,−b−3)"]
    },
    {
      "id": "q1s2",
      "section": "第（2）①问",
      "title": "第2步：比较 AD 与 BC",
      "t": 2.5,
      "derive": [
        ["∵", "A(−1,0)，D(b＋2,−b−3)"],
        ["∴", "AD＝√[(b＋3)²＋(b＋3)²]＝(b＋3)√2"],
        ["∵", "B(b＋1,0)，C(0,b＋1)"],
        ["∴", "BC＝√[(b＋1)²＋(b＋1)²]＝(b＋1)√2"],
        ["∵", "AD＝2BC"],
        ["∴", "(b＋3)√2＝2(b＋1)√2"],
        ["∴", "b＝1"]
      ],
      "box": ["b＝1"]
    },
    {
      "id": "q2s1",
      "section": "第（2）②问",
      "title": "第1步：构造 30° 直角三角形，转换线段",
      "t": 2.6,
      "derive": [
        ["∴", "2DM＋AM＝2(DM＋1/2 AM)"],
        ["作", "在过 A 且与 x 轴夹角为 30° 的固定射线上取 N，使 ∠ANM＝90°"],
        ["∵", "Rt△AMN 中，30°角所对直角边等于斜边的一半"],
        ["∴", "MN＝1/2 AM"],
        ["∴", "2DM＋AM＝2(DM＋MN)"]
      ],
      "box": ["MN＝1/2 AM", "2DM＋AM＝2(DM＋MN)"]
    },
    {
      "id": "q2s2",
      "section": "第（2）②问",
      "title": "第2步：将军饮马，折线 D-M-N 三点共线时最短",
      "t": 2.6,
      "derive": [
        ["∵", "两点之间线段最短"],
        ["∴", "DM＋MN≥DN"],
        ["∴", "折线 D-M-N 拉直时最短"],
        ["∴", "最短时 D、M、N 三点共线"],
        ["∵", "N 在固定射线 AN 上"],
        ["∴", "最小值还需 DN⊥AN"],
        ["∴", "最小值对应 DM＋MN＝DN"],
        ["∴", "2DM＋AM 的最小值为 2DN"]
      ],
      "box": [],
      "localControls": {
        "values": { "u": 2.2 },
        "note": "拖动 M，观察折线 D-M-N 在三点共线时最短。",
        "controls": [
          { "var": "u", "label": "动点 M：横坐标", "min": 0.2, "max": 3.95, "step": 0.01, "precision": 2 }
        ]
      }
    },
    {
      "id": "q2s3",
      "section": "第（2）②问",
      "title": "第3步：计算 DN，再代入给定最小值求 b",
      "t": 2.6,
      "derive": [
        ["作", "DP⊥x轴，垂足为 P"],
        ["∵", "D(b＋2,−b−3)", { "refStep": "q1s1", "refLabel": "回看坐标通式" }],
        ["∴", "DP＝AP＝b＋3"],
        ["∵", "最短时 D、M、N 三点共线，且 ∠MAN＝30°，∠ANM＝90°"],
        ["∴", "∠DMP＝60°"],
        ["∴", "Rt△DPM 中，MP＝DP/√3＝(b＋3)/√3"],
        ["∵", "AP＝DP＝AM＋MP"],
        ["∴", "AM＝(b＋3)−(b＋3)/√3"],
        ["∴", "DM＝2(b＋3)/√3，MN＝AM/2"],
        ["∴", "DN＝DM＋MN＝(b＋3)(1＋√3)/2"],
        ["∴", "2DM＋AM 的最小值为 2DN＝(b＋3)(1＋√3)"],
        ["∵", "题中最小值为 5＋5√3＝5(1＋√3)"],
        ["∴", "(b＋3)(1＋√3)＝5(1＋√3)"],
        ["∴", "b＋3＝5"],
        ["∴", "b＝2"]
      ],
      "box": []
    }
  ],
