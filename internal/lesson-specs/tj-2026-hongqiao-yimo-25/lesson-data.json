    "pageDescription": "红桥区一模第 25 题：由已知根因式分解二次函数，再结合对称点、交点和面积求点 M。",
    "breadcrumbTitle": "2026 天津市红桥区一模 第 25 题"
  },
  "problem": {
    "summary": "抛物线 y=ax²+bx+c 过 A(−1,0)，求顶点、系数 a 和第三象限点 M。",
    "lines": [
      { "text": "已知抛物线 y=ax²+bx+c（a，b，c 为常数，a<0，b>0）经过点 A(−1,0)。" },
      { "text": "（Ⅰ）当 b=2，c=4 时，求该抛物线顶点 P 的坐标；", "answerId": "answerI", "answer": "答案：P(1/2, 9/2)" },
      { "text": "（Ⅱ）点 B 是抛物线与 x 轴的另一个交点，点 C 是抛物线与 y 轴的交点。" },
      { "text": "① 当 c=4/3 时，若 ∠CAB=2∠ABC，求 a 的值；", "answerId": "answerII1", "answer": "答案：a=-1/2" },
      { "text": "② M 为第三象限内抛物线上一点，若 BO=4CO，∠ABM=∠ABC，当 S△MBC=8b+6 时，求点 M 的坐标。", "answerId": "answerII2", "answer": "答案：M(−2, −5/2)" }
    ]
  },
  "ui": {
    "legend": [
      { "colorVar": "paper", "label": "第（Ⅰ）问抛物线 y=-2x²+2x+4" },
      { "colorVar": "fold", "label": "第（Ⅱ）问当前步骤抛物线" }
    ],
    "sliderLabel": "参数 b",
    "paramLabelPrefix": "b=",
    "goToProblemMode": "doubleScroll",
    "groupTitles": {
      "第（Ⅰ）问": "第（Ⅰ）问  求顶点 P",
      "第（Ⅱ）①问": "第（Ⅱ）①  角关系求 a",
      "第（Ⅱ）②问": "第（Ⅱ）②  面积条件求 M"
    }
  },
  "steps": [
    {
      "id": "i1s1",
      "section": "第（Ⅰ）问",
      "title": "第1步：求出解析式并得到顶点 P",
      "t": 1.2,
      "derive": [
        ["∵", "抛物线经过 A(−1,0)"],
        ["∴", "a−b+c=0"],
        ["∵", "b=2，c=4"],
        ["∴", "a−2+4=0"],
        ["∴", "a=-2"],
        ["∴", "y=-2x²+2x+4"],
        ["∴", "xP=-b/(2a)=1/2"],
        ["∴", "yP=-2·(1/2)²+2·(1/2)+4=9/2"],
        ["∴", "P(1/2,9/2)"]
      ],
      "box": ["y=-2x²+2x+4", "P(1/2, 9/2)"]
    },
    {
      "id": "q1s1",
      "section": "第（Ⅱ）①问",
      "title": "第1步：代入 c 并化简函数表达式",
      "t": 1.2,
      "derive": [
        ["∵", "A(−1,0) 是 x 轴交点"],
        ["∴", "x=-1 是方程 ax²+bx+c=0 的一个根"],
        ["∵", "a−b+c=0"],
        ["∴", "b=a+c"],
        ["∵", "c=4/3"],
        ["∴", "y=ax²+(a+4/3)x+4/3"],
        ["∴", "y=(x+1)(ax+4/3)"],
        ["∴", "B(−4/(3a),0)，C(0,4/3)"]
      ],
      "box": ["y=(x+1)(ax+4/3)", "B(−4/(3a),0)"]
    },
    {
      "id": "q1s2",
      "section": "第（Ⅱ）①问",
      "title": "第2步：构造等腰三角形求解",
      "t": 1.2,
      "derive": [
        ["∵", "c=4/3"],
        ["∴", "C(0,4/3)，AO=1，CO=4/3，AC=5/3"],
        ["作", "点 A′ 为 A 关于 y 轴的对称点，连接 CA′"],
        ["∴", "A′(1,0)，CA′=CA=5/3"],
        ["∴", "∠CA′A=∠CAB=2∠ABC"],
        ["∴", "∠CA′B=180°−2∠ABC"],
        ["∴", "△CA′B 中，∠A′CB=∠ABC"],
        ["∴", "A′C=A′B"],
        ["∴", "A′B=5/3"],
        ["∴", "BO=OA′+A′B=1+5/3=8/3"],
        ["∵", "由第1步 B(−4/(3a),0)"],
        ["∴", "−(4/3)/a=8/3"],
        ["∴", "a=-1/2"]
      ],
      "box": ["B(8/3, 0)", "a=-1/2"]
    },
    {
      "id": "q2s1",
      "section": "第（Ⅱ）②问",
      "title": "第1步：由 BO=4CO 化简函数表达式",
      "t": 1.2,
      "derive": [
        ["∵", "由 A(−1,0) 和 b=a+c"],
        ["∴", "y=(x+1)(ax+c)"],
        ["∴", "B(−c/a,0)"],
        ["∵", "BO=4CO"],
        ["∴", "−c/a=4c"],
        ["∵", "c≠0"],
        ["∴", "a=-1/4"],
        ["∵", "b=a+c"],
        ["∴", "c=b+1/4"],
        ["∴", "y=-1/4x²+bx+b+1/4"],
        ["∴", "B(4b+1,0)，C(0,b+1/4)"]
      ],
      "box": ["a=-1/4", "y=-1/4x²+bx+b+1/4", "B(4b+1,0)", "C(0,b+1/4)"]
    },
    {
      "id": "q2s2",
      "section": "第（Ⅱ）②问",
      "title": "第2步：由等角作 C′ 确定 BM",
      "t": 1.2,
      "derive": [
        ["作", "BM 交 y 轴于点 C′"],
        ["∵", "∠ABM=∠ABC，M 在第三象限"],
        ["∴", "C′O=CO=b+1/4"],
        ["∴", "C′(0,−b−1/4)"],
        ["∵", "B(4b+1,0)"],
        ["∴", "BM: y=1/4(x−4b−1)"],
        ["∵", "抛物线 y=-1/4x²+bx+b+1/4"],
        ["∴", "联立得 x²+(1−4b)x−8(b+1/4)=0"],
        ["∵", "一个根为 xB=4b+1"],
        ["∴", "另一个根 xM=-2"],
        ["∴", "M(−2,−b−3/4)"]
      ],
      "box": ["M(−2, −b−3/4)"]
    },
    {
      "id": "q2s3",
      "section": "第（Ⅱ）②问",
      "title": "第3步：用铅垂面积方程求 b",
      "t": 1.2,
      "derive": [
        ["∵", "C′ 在 BM 上，C′O=CO=b+1/4"],
        ["∴", "CC′=2b+1/2"],
        ["∵", "B 到 y 轴距离为 4b+1，M 到 y 轴距离为 2"],
        ["∴", "S△MBC=1/2·CC′·(4b+1)+1/2·CC′·2"],
        ["∴", "S△MBC=1/2·(2b+1/2)·(4b+3)"],
        ["∴", "S△MBC=4b²+4b+3/4"],
        ["∵", "S△MBC=8b+6"],
        ["∴", "4b²+4b+3/4=8b+6"],
        ["∴", "16b²−16b−21=0"],
        ["∴", "b=7/4 或 b=-3/4"],
        ["∵", "b>0"],
        ["∴", "b=7/4"]
      ],
      "box": ["b=7/4"]
    },
    {
      "id": "q2s4",
      "section": "第（Ⅱ）②问",
      "title": "第4步：代回得到 M 的坐标",
      "t": 1.75,
      "derive": [
        ["∵", "M(−2,−b−3/4)"],
        ["∵", "b=7/4"],
        ["∴", "yM=-7/4−3/4=-5/2"],
        ["∴", "M(−2,−5/2)"]
      ],
      "box": ["M(−2, −5/2)"]
    }
  ],
