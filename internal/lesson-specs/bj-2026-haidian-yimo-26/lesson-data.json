  "steps": [
    {
      "id": "i1s1",
      "section": "第（1）问",
      "title": "第1步：由过原点求 c",
      "t": 0.5,
      "derive": [
        ["∵", "抛物线 y＝ax²＋bx＋c 过 O(0，0)"],
        ["∴", "0＝c"],
        ["∴", "c＝0"]
      ],
      "box": ["c＝0"]
    },
    {
      "id": "i1s2",
      "section": "第（1）问",
      "title": "第2步：由过 (2，0) 求 b",
      "t": 0.5,
      "derive": [
        ["∵", "c＝0 且抛物线过 (2，0)"],
        ["∴", "0＝4a＋2b"],
        ["∴", "b＝－2a"],
        ["∴", "y＝ax²－2ax"]
      ],
      "box": ["b＝－2a", "y＝ax²－2ax"]
    },
    {
      "id": "q2s1",
      "section": "第（2）①问",
      "title": "第1步：用 t 表示 M、N 与 m",
      "t": 0.5,
      "derive": [
        ["∵", "M 是 x＝t 与抛物线的交点"],
        ["∴", "M(t，at²－2at)"],
        ["∵", "N 是 x＝t 与直线 y＝－ax＋2a 的交点"],
        ["∴", "N(t，－at＋2a)"],
        ["∴", "m＝|(at²－2at)－(－at＋2a)|"],
        ["∴", "m＝a|t²－t－2|（a＞0）"]
      ],
      "box": ["M(t，at²－2at)", "N(t，－at＋2a)", "m＝a|t²－t－2|"]
    },
    {
      "id": "q2s2",
      "section": "第（2）①问",
      "title": "第2步：m＝0 求 t",
      "t": -1,
      "derive": [
        ["∵", "m＝0"],
        ["∴", "a(t²－t－2)＝0"],
        ["∵", "a＞0"],
        ["∴", "t²－t－2＝0"],
        ["∴", "(t＋1)(t－2)＝0"],
        ["∴", "t＝－1 或 t＝2"]
      ],
      "box": ["t＝－1 或 t＝2"]
    },
    {
      "id": "q2s3",
      "section": "第（2）②问",
      "title": "第1步：把 m＜9 写成 a 与 |t²－t－2|",
      "t": 0.5,
      "derive": [
        ["∵", "当－2＜t＜2 时总有 m＜9"],
        ["∴", "a|t²－t－2|＜9 对任意 t∈(－2，2) 成立"],
        ["∵", "t→－2⁺ 时 t²－t－2→4"],
        ["∴", "|t²－t－2| 可无限接近 4"],
        ["∴", "须有 4a≤9"],
        ["∵", "a＞0"],
        ["∴", "0＜a≤9/4"]
      ],
      "box": ["恒成立 ⇒ a·sup|t²－t－2| 不超过 9", "0＜a≤9/4"]
    },
    {
      "id": "q2s4",
      "section": "第（2）②问",
      "title": "第2步：比较区间内“中部”最大值",
      "t": 0.5,
      "derive": [
        ["∵", "在(－1，2) 上 t²－t－2≤0"],
        ["∴", "|t²－t－2| 在 t＝1/2 处取最大 9/4"],
        ["∵", "9/4＜4"],
        ["∴", "紧约束来自 t 靠近－2 而非 t＝1/2"],
        ["∴", "0＜a≤9/4"]
      ],
      "box": ["sup(－2，2) |t²－t－2|＝4（开区间上不取到）", "0＜a≤9/4"]
    }
  ],
