        ["∴", "△BDE∽△BAC"],
        ["∴", "BE/AB＝BD/BC，DE/AC＝BD/BC"],
        ["∴", "BE＝a(1＋x²)/(2x)，DE＝a√(1＋x²)/(2x)"],
        ["∴", "CE＝BC－BE＝a(x²－1)/(2x)"]
      ],
      "box": ["△BDE∽△BAC", "CE＝a(x²－1)/(2x)"]
