  "steps": [
    {
      "id": "i1s1",
      "section": "第（I）问",
      "title": "第1步：由分解式直接读出 A、B、C",
      "t": 1,
      "derive": [
        ["∵", "a＝−1，b＝2，c＝3"],
        ["∴", "y＝−x²＋2x＋3"],
        ["∴", "y＝−(x−3)(x＋1)"],
        ["∴", "与 x 轴交于 (−1,0)，(3,0)"],
        ["∵", "点 A 在点 B 左侧"],
        ["∴", "A(−1,0)，B(3,0)"],
        ["∵", "x＝0 时，y＝3"],
        ["∴", "C(0,3)"]
      ],
      "box": ["A(−1,0)", "B(3,0)", "C(0,3)"]
    },
    {
      "id": "q1s1",
      "section": "第（II）①问",
      "title": "第1步：用根与 C 点求 a",
      "t": 3,
      "derive": [
        ["∵", "A(−m,0)，B(n,0)"],
        ["∴", "y＝a(x＋m)(x−n)"],
        ["∵", "C(0,3m) 在抛物线上"],
        ["∴", "3m＝a·m·(−n)＝−amn"],
        ["∵", "m＞0"],
        ["∴", "a＝−3/n"],
        ["∵", "n＝6"],
        ["∴", "a＝−1/2"]
      ],
      "box": ["a＝−1/2"]
    },
    {
      "id": "q1s2",
      "section": "第（II）①问",
      "title": "第2步：构造全等三角形得到 D，再求 E、F 和 EF",
      "t": 3,
      "derive": [
        ["∵", "m＝3"],
        ["∴", "A(−3,0)，C(0,9)"],
        ["作", "过 D 作 DG⊥OC，垂足为 G"],
        ["∵", "AC 绕 C 逆时针旋转 90° 得 DC"],
        ["∴", "AC＝DC，∠ACD＝90°"],
        ["∵", "∠AOC＝∠DGC＝90°"],
        ["∴", "∠ACO＝∠CDG"],
        ["∴", "△AOC≌△CDG"],
        ["∴", "CG＝AO＝3，DG＝OC＝9"],
        ["∴", "G(0,6)，D(9,6)"],
        ["∵", "E 是 AD 中点"],
        ["∴", "E(3,3)"],
        ["∵", "EF∥y轴，F 在抛物线上"],
        ["∴", "F 的横坐标为 3"],
        ["∵", "n＝6，y＝−1/2(x＋3)(x−6)"],
        ["∴", "F(3,9)，E(3,3)"],
        ["∴", "EF＝6"]
      ],
      "box": ["D(9,6)", "E(3,3)", "F(3,9)", "EF＝6"]
    },
    {
      "id": "q2s1",
      "section": "第（II）②问",
      "title": "第1步：由平行四边形推出 B 坐标，推导函数表达式",
      "t": 0.75,
      "derive": [
        ["∵", "由上一步全等直角三角形思路", { "refStep": "q1s2", "refLabel": "回看第（II）①第2步" }],
        ["∴", "D(3m,2m)"],
        ["∵", "A(−m,0)，E 是 AD 中点"],
        ["∴", "E(m,m)"],
        ["∵", "EF∥y轴"],
        ["∴", "F 的横坐标为 m"],
        ["∵", "M 在 y 轴上"],
        ["∴", "M 的横坐标为 0"],
        ["∵", "四边形 MFDB 是平行四边形"],
        ["∴", "对角线 MD 与 FB 的中点相同，即 M＋D＝F＋B"],
        ["∴", "0＋3m＝m＋n"],
        ["∴", "n＝2m"],
        ["∴", "B(2m,0)"],
        ["∵", "a＝−3/n", { "refStep": "q1s1", "refLabel": "回看第（II）①第1步" }],
        ["∴", "a＝−3/(2m)"],
        ["∴", "y＝−3/(2m)(x＋m)(x−2m)"],
        ["∴", "y＝−3/(2m)x²＋(3/2)x＋3m"]
      ],
      "box": ["n＝2m", "y＝−3/(2m)x²＋(3/2)x＋3m"]
    },
    {
      "id": "q2s2",
      "section": "第（II）②问",
      "title": "第2步：用对称轴把 PB−PM 转化为 PA−PM",
      "t": 0.75,
      "derive": [
        ["∵", "抛物线 y＝−3/(2m)x²＋(3/2)x＋3m"],
        ["∴", "对称轴 x＝m/2"],
        ["∵", "A(−m,0)，B(2m,0) 关于对称轴对称"],
        ["∴", "点 P 在对称轴上时，PA＝PB"],
        ["∵", "F 的横坐标为 m"],
        ["∴", "F(m,3m)"],
        ["∵", "M＋D＝F＋B"],
        ["∴", "M(0,m)"],
        ["∴", "PB−PM＝PA−PM"],
        ["∵", "在△APM中，PA−PM≤AM"],
        ["∴", "PB−PM≤AM"]
      ],
      "box": ["PA＝PB", "PB−PM＝PA−PM≤AM"],
      "localControls": {
        "values": { "p": 1.5 },
        "note": "拖动 P：当 A、P、M 三点共线时，PA−PM 取到最大值 AM。",
        "controls": [
          { "var": "p", "label": "点 P：y/m", "min": -0.2, "max": 3, "step": 0.01, "scale": 1, "precision": 2 }
        ]
      }
    },
    {
      "id": "q2s3",
      "section": "第（II）②问",
      "title": "第3步：AM即最大值，写出最终解析式和 P",
      "t": 0.75,
      "derive": [
        ["∵", "PB−PM≤AM"],
        ["∴", "当 A、P、M 三点共线时，PB−PM 取得最大值 AM"],
        ["∵", "A(−m,0)，M(0,m)"],
        ["∴", "AM＝m√2"],
        ["∵", "题中最大值为 3√2/4"],
        ["∴", "m＝3/4"],
        ["∴", "a＝−3/(2m)＝−2，b＝3/2，c＝3m＝9/4"],
        ["∴", "y＝−2x²＋(3/2)x＋9/4"],
        ["∵", "直线 AM 与对称轴 x＝m/2 交于 P(m/2,3m/2)"],
        ["∴", "P(3/8,9/8)"]
      ],
      "box": ["y＝−2x²＋(3/2)x＋9/4", "P(3/8, 9/8)"]
    }
  ],
