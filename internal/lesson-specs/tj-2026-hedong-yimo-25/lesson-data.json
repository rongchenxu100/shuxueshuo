    "groupTitles": {
      "第（Ⅰ）问": "第（Ⅰ）问  求顶点 P",
      "第（Ⅱ）①问": "第（Ⅱ）①  直角等腰求 D",
      "第（Ⅱ）②问": "第（Ⅱ）②  角度与最短路求 E"
    }
  },
  "steps": [
    {
      "id": "i1s1",
      "section": "第（Ⅰ）问",
      "title": "第1步：配方求顶点 P",
      "t": -6.5,
      "derive": [
        ["∵", "a＝1，b＝−2，c＝−3"],
        ["∴", "y＝x²−2x−3"],
        ["∴", "y＝(x−1)²−4"],
        ["∴", "顶点 P(1,−4)"]
      ],
      "box": ["P(1, −4)"]
    },
    {
      "id": "q1s1",
      "section": "第（Ⅱ）①问",
      "title": "第1步：由 A 坐标化简抛物线，读出 B、C",
      "t": -4,
      "derive": [
        ["∵", "A(−1,0) 在抛物线上"],
        ["∴", "a−b＋c＝0"],
        ["∵", "a＝2"],
        ["∴", "b＝c＋2"],
        ["∴", "y＝2x²＋(c＋2)x＋c"],
        ["∴", "y＝(x＋1)(2x＋c)"],
        ["∴", "另一个交点 B(−c/2,0)，C(0,c)"]
      ],
      "box": ["y＝(x＋1)(2x＋c)", "B(−c/2,0)", "C(0,c)"]
    },
    {
      "id": "q1s2",
      "section": "第（Ⅱ）①问",
      "title": "第2步：由全等三角形求D点坐标表达式",
      "t": -4,
      "derive": [
        ["作", "DQ⊥x轴，垂足为 Q"],
        ["∵", "∠CBD＝90°，BC＝BD"],
        ["∵", "B(−c/2,0)，C(0,c)"],
        ["∴", "BO＝−c/2，CO＝−c"],
        ["∵", "∠COB＝∠DQB＝90°"],
        ["∵", "∠CBO＝∠BDQ"],
        ["∴", "Rt△CBO≌Rt△BDQ"],
        ["∴", "BQ＝CO＝−c，DQ＝BO＝−c/2"],
        ["∴", "Q(c/2,0)，D(c/2,−c/2)"]
      ],
      "box": ["D(c/2, −c/2)"]
    },
    {
      "id": "q1s3",
      "section": "第（Ⅱ）①问",
      "title": "第3步：代入抛物线求出 D",
      "t": -2.5,
      "derive": [
        ["∵", "D(c/2,−c/2) 在抛物线上"],
        ["∵", "抛物线可写成 y＝(x＋1)(2x＋c)"],
        ["∴", "−c/2＝(c/2＋1)(2·c/2＋c)"],
        ["∴", "−c/2＝c(c＋2)"],
        ["∵", "c≠0"],
        ["∴", "c＝−5/2"],
        ["∴", "D(−5/4,5/4)"]
      ],
      "box": ["c＝−5/2", "D(−5/4, 5/4)"]
    },
    {
      "id": "q2s1",
      "section": "第（Ⅱ）②问",
      "title": "第1步：由A和B坐标化简函数表达式",
      "t": -6.5,
      "derive": [
        ["∵", "A(−1,0)，B(−c,0) 是抛物线与 x 轴交点"],
        ["∴", "y＝a(x＋1)(x＋c)"],
        ["∵", "常数项为 c"],
        ["∴", "ac＝c"],
        ["∵", "c≠0"],
        ["∴", "a＝1"],
        ["∴", "b＝c＋1"],
        ["∵", "b＜0"],
        ["∴", "c＜−1"],
        ["∴", "抛物线为 y＝x²＋(c＋1)x＋c"]
      ],
      "box": ["a＝1", "b＝c＋1", "c＜−1", "y＝x²＋(c＋1)x＋c"]
    },
    {
      "id": "q2s2",
      "section": "第（Ⅱ）②问",
      "title": "第2步：由角度条件确定 E",
      "t": -6.5,
      "derive": [
        ["设", "E(0,y)，其中 c≤y≤0"],
        ["∵", "B(−c,0)，C(0,c)，且 c＜−1"],
        ["∴", "OB＝OC＝−c"],
        ["∴", "直线 BC 与 BA 的夹角为 45°"],
        ["∵", "∠ABE＝2∠CBE"],
        ["∴", "∠ABE＝30°"],
        ["∵", "tan∠ABE＝(−y)/(−c)"],
        ["∴", "(−y)/(−c)＝1/√3"],
        ["∴", "y＝c/√3"],
        ["∴", "E(0,c/√3)"]
      ],
      "box": ["∠ABE＝30°", "E(0, c/√3)"]
    },
    {
      "id": "q2s3",
      "section": "第（Ⅱ）②问",
      "title": "第3步：求 BE 与对称轴的交点 F",
      "t": -6.5,
      "derive": [
        ["∵", "抛物线为 y＝x²＋(c＋1)x＋c"],
        ["∴", "对称轴 l：x＝−(c＋1)/2"],
        ["∵", "B(−c,0)，E(0,c/√3)"],
        ["∴", "直线 BE：y＝(x＋c)/√3"],
        ["∴", "F(−(c＋1)/2, (c−1)/(2√3))"]
      ],
      "box": ["F(−(c＋1)/2, (c−1)/(2√3))"]
    },
    {
      "id": "q2s4",
      "section": "第（Ⅱ）②问",
      "title": "第4步：用两次对称把折线路径拉直",
      "t": -6.5,
      "derive": [
        ["作", "点 A 关于 BE 的对称点 A′，点 F 关于 BA 的对称点 F′"],
        ["∵", "G 在 BE 上"],
        ["∴", "AG＝A′G"],
        ["∵", "H 在 BA 上"],
        ["∴", "FH＝F′H"],
        ["∴", "AG＋GH＋FH＝A′G＋GH＋F′H"],
        ["∵", "两点之间线段最短"],
        ["∴", "A′G＋GH＋F′H≥A′F′"],
        ["∴", "当 A′、G、H、F′ 共线时取得最小值"]
      ],
      "box": ["最小值＝A′F′"],
      "localControls": {
        "values": { "u": 0.576923, "v": 0.5 },
        "note": "拖动 G、H，观察折线路径被两次对称拉成 A′F′。",
        "controls": [
          { "var": "u", "label": "动点 G：BG/BE", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 },
          { "var": "v", "label": "动点 H：AH/AB", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 }
        ]
      }
    },
    {
      "id": "q2s5",
      "section": "第（Ⅱ）②问",
      "title": "第5步：由最小值求 c，得到 E",
      "t": -6.5,
      "derive": [
        ["∵", "A′ 是 A 关于 BE 的对称点"],
        ["∴", "BE 垂直平分 AA′，且 BA＝BA′"],
        ["∵", "∠ABE＝30°"],
        ["∴", "∠ABA′＝60°"],
        ["∴", "△ABA′ 是等边三角形"],
        ["∴", "A′ 在 AB 的垂直平分线上，即 x＝−(c＋1)/2"],
        ["∵", "AB＝−c＋1＝1−c"],
        ["∴", "等边三角形高为 √3(1−c)/2"],
        ["∵", "A′ 在 x 轴下方"],
        ["∴", "A′ 的纵坐标为 −√3(1−c)/2＝√3(c−1)/2"],
        ["∴", "A′(−(c＋1)/2, √3(c−1)/2)"],
        ["∵", "F(−(c＋1)/2, (c−1)/(2√3))，F′ 是 F 关于 x 轴的对称点"],
        ["∴", "F′(−(c＋1)/2, −(c−1)/(2√3))"],
        ["∴", "A′F′＝−2(c−1)/√3"],
        ["∵", "最小值为 5√3"],
        ["∴", "−2(c−1)/√3＝5√3"],
        ["∴", "c＝−13/2"],
        ["∴", "E(0,c/√3)＝(0,−13√3/6)"]
      ],
      "box": ["c＝−13/2", "E(0, −13√3/6)"]
    }
  ],
