      "section": "第（III）问",
      "title": "第2步：由边界代入求最小候选",
      "t": 1,
      "derive": [
        ["∵", "t=1 时，重合部分为 △EFH，EF=1/√3，HF=√3/6"],
        ["∵", "以 EF 为底，三角形的高为 HF·cos30°=1/4"],
        ["∴", "S=1/2·EF·1/4=√3/24"],
        ["∵", "t=4 时，重合部分为 △DFB"],
