        ["∵", "折叠保持长度"],
        ["∴", "A′F=AF=t/√3"],
        ["∵", "折叠保持角度，∠FAO=30°"],
        ["∴", "∠FA′H=30°"],
        ["∵", "A′O′ 是 AO 的对应边，H 在 A′O′ 与 AB 的交点上"],
        ["∴", "A′H⊥FH，△A′FH 是直角三角形"],
        ["∴", "HF=A′F·sin30°=√3t/6"]
      ],
      "box": ["AF=A′F=t/√3", "AK=t/2"]
