        ["∴", "AB 与 x 轴负方向的夹角为 30°，即 ∠EAF=30°"],
        ["∵", "∠AEF=30°"],
        ["∴", "△EFA 为等腰三角形"],
        ["作", "FK⊥AE，垂足为 K"],
        ["∵", "等腰三角形底边上的高也是中线"],
        ["∴", "AK=EK=AE/2=t/2"],
        ["∴", "K(3-t/2,0)"],
        ["∵", "在 Rt△AFK 中，∠KAF=30°"],
        ["∴", "FK=AK·tan30°=√3t/6"],
        ["∴", "F(3-t/2,√3t/6)"],
        ["∵", "t=1"],
        ["∴", "F(5/2,√3/6)"]
      ],
