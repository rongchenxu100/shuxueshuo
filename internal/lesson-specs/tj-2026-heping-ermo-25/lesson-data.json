        ["∴", "0＝−c²−bc＋c＝c(1−c−b)"],
        ["∵", "c＞1"],
        ["∴", "b＝1−c"],
        ["∴", "y＝−x²＋(1−c)x＋c"],
        ["∵", "一个根为 −c，两根之和为 1−c"],
        ["∴", "另一个根为 1，即 B(1,0)"],
        ["∵", "对称轴 x＝b/2＝(1−c)/2"],
        ["∴", "M((1−c)/2,0)"]
