  "problem": {
    "summary": "2026 年天津市红桥区三模第 25 题（二次函数综合）",
    "lines": [
      { "text": "25.（2026·红桥三模）已知抛物线 y＝ax²＋bx＋c（a，b，c 为常数，a＞0）与 x 轴相交于点 A，B（点 A 在点 B 的左侧），与 y 轴相交于点 C，且 4a＋b＝0，过点 C 作 x 轴的平行线与抛物线相交于点 D。" },
      { "text": "（1）若 a＝1，c＝−5" },
      { "text": "① 求该抛物线的顶点 P 的坐标；", "answerId": "answerI1", "answer": "P(2,−9)" },
      { "text": "② 点 M 在抛物线上，以 CD 为边的 ▱CDME 的顶点 E 在直线 BC 上，求点 M 的坐标。", "answerId": "answerI2", "answer": "M(1,−8)" },
      { "text": "（2）若点 A(−1,0)，点 F 在抛物线的对称轴上，以 AC 为边作 ▱ACFG，当 BF＋BG 取得最小值 7√2 时，求 a 的值。", "answerId": "answerII", "answer": "a＝7/5" }
    ]
  },
  "ui": {
    "legend": [
      { "colorVar": "paper", "label": "抛物线与坐标轴" },
      { "colorVar": "fold", "label": "平行四边形与平移转化" },
      { "colorVar": "overlap", "label": "最短路径与关键线段" }
    ],
    "sliderLabel": "动点 F 在对称轴上的位置",
    "paramLabelPrefix": "u=",
    "goToProblemMode": "doubleScroll",
    "groupTitles": {
      "第（1）①问": "第（1）①  求顶点 P",
      "第（1）②问": "第（1）②  求点 M",
      "第（2）问": "第（2）  路径最小值反求 a"
    }
  },
  "steps": [
    {
      "id": "i1s1",
      "section": "第（1）①问",
      "title": "第1步：化简函数表达式并求顶点",
      "t": -3,
      "derive": [
        ["∵", "a＝1，c＝−5，4a＋b＝0"],
        ["∴", "b＝−4"],
        ["∴", "y＝x²−4x−5"],
        ["∴", "y＝(x−2)²−9"],
        ["∴", "顶点 P(2,−9)"]
      ],
      "box": ["P(2,−9)"]
    },
    {
      "id": "i2s1",
      "section": "第（1）②问",
      "title": "第1步：由水平线求 D，设 E 表示 M",
      "t": -3,
      "derive": [
        ["∵", "y＝x²−4x−5"],
        ["∴", "A(−1,0)，B(5,0)，C(0,−5)"],
        ["∵", "过 C 作 x 轴平行线与抛物线另交于 D"],
        ["∴", "D(4,−5)"],
        ["∵", "B(5,0)，C(0,−5)"],
        ["∴", "直线 BC：y＝x−5"],
        ["设", "E(s,s−5)"],
        ["∵", "▱CDME 中，DM∥CE 且 DM＝CE"],
        ["∴", "M(4＋s,s−5)"]
      ],
      "box": ["D(4,−5)", "M(4＋s,s−5)"]
    },
    {
      "id": "i2s2",
      "section": "第（1）②问",
      "title": "第2步：点 M 在抛物线上求坐标",
      "t": -3,
      "derive": [
        ["∵", "M(4＋s,s−5) 在 y＝x²−4x−5 上"],
        ["∴", "s−5＝(4＋s)²−4(4＋s)−5"],
        ["∴", "s−5＝s²＋4s−5"],
        ["∴", "s²＋3s＝0"],
        ["∴", "s＝0 或 s＝−3"],
        ["∵", "s＝0 时 E＝C，M＝D，平行四边形退化"],
        ["∴", "s＝−3"],
        ["∴", "M(1,−8)"]
      ],
      "box": ["M(1,−8)"]
    },
    {
      "id": "q2s1",
      "section": "第（2）问",
      "title": "第1步：由已知根和对称轴写出 B、C",
      "t": -3,
      "derive": [
        ["∵", "4a＋b＝0"],
        ["∴", "b＝−4a，对称轴为 x＝2"],
        ["∵", "A(−1,0) 是左侧交点"],
        ["∴", "另一个 x 轴交点为 B(5,0)"],
        ["∴", "y＝a(x＋1)(x−5)"],
        ["∴", "C(0,−5a)"]
      ],
      "box": ["B(5,0)", "C(0,−5a)", "对称轴 x＝2"]
    },
    {
      "id": "q2s2",
      "section": "第（2）问",
      "title": "第2步：由平行四边形表示 G",
      "t": -3,
      "derive": [
        ["设", "F(2,u)"],
        ["∵", "▱ACFG 中，AG∥CF 且 AG＝CF"],
        ["∵", "A(−1,0)，C(0,−5a)，F(2,u)"],
        ["∴", "从 C 到 F：横向向右 2，纵向向上 u＋5a"],
        ["∴", "从 A 到 G 也横向向右 2，纵向向上 u＋5a"],
        ["∴", "G(1,u＋5a)"],
        ["∴", "F 在 x＝2 上运动，G 在 x＝1 上同步运动"]
      ],
      "box": ["F(2,u)", "G(1,u＋5a)"]
    },
    {
      "id": "q2s3",
      "section": "第（2）问",
      "title": "第3步：构建平行四边形，将双动点问题转化为单动点问题",
      "t": -3,
      "derive": [
        ["作", "平行四边形 BGFB₁"],
        ["∴", "B₁F∥BG，且 B₁F＝BG"],
        ["∵", "从 G 到 F：横向向右 1，纵向向下 5a"],
        ["∴", "从 B 到 B₁ 也横向向右 1，纵向向下 5a"],
        ["∴", "B₁(6,−5a)"],
        ["∴", "BG＝B₁F"],
        ["∴", "BF＋BG＝BF＋B₁F"],
        ["∴", "原来的 F、G 两个动点，转化为只研究动点 F 的折线"]
      ],
      "box": ["B₁(6,−5a)", "BF＋BG＝BF＋B₁F"],
      "localControls": {
        "values": { "v": -3 },
        "note": "拖动 F 或 G，观察两个动点按平行四边形关系联动。",
        "controls": [
          { "var": "v", "label": "动点 F：纵坐标", "min": -8, "max": 2, "step": 0.1, "scale": 1, "precision": 1 },
          { "var": "v", "label": "动点 G：随 F 联动", "min": -8, "max": 2, "step": 0.1, "scale": 1, "precision": 1 }
        ]
      }
    },
    {
      "id": "q2s4",
      "section": "第（2）问",
      "title": "第4步：反射拉直求最小值",
      "t": -3,
      "derive": [
        ["∵", "A(−1,0)，B(5,0) 关于对称轴 x＝2 对称"],
        ["∵", "F 在对称轴 x＝2 上"],
        ["∴", "BF＝AF"],
        ["∴", "BF＋B₁F＝AF＋B₁F"],
        ["∵", "AF＋B₁F≥AB₁"],
        ["∴", "当 A，F，B₁ 三点共线时，BF＋BG 最小"],
        ["∴", "最小值为 AB₁"]
      ],
      "box": ["最短时 A，F，B₁ 三点共线", "最小值为 AB₁"],
      "localControls": {
        "values": { "v": -3 },
        "note": "拖动 F，观察折线 A-F-B₁；三点共线时最短。",
        "controls": [
          { "var": "v", "label": "动点 F：纵坐标", "min": -8, "max": 2, "step": 0.1, "scale": 1, "precision": 1 }
        ]
      }
    },
    {
      "id": "q2s5",
      "section": "第（2）问",
      "title": "第5步：由最小值反求 a",
      "t": -3,
      "derive": [
        ["∵", "A(−1,0)，B₁(6,−5a)"],
        ["∴", "AB₁²＝7²＋(5a)²＝49＋25a²"],
        ["∵", "BF＋BG 的最小值为 7√2"],
        ["∴", "AB₁＝7√2"],
        ["∴", "49＋25a²＝98"],
        ["∴", "a²＝49/25"],
        ["∵", "a＞0"],
        ["∴", "a＝7/5"]
      ],
      "box": ["a＝7/5"]
    }
  ],
