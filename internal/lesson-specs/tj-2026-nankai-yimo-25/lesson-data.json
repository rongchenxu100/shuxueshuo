  "steps": [
    {
      "id": "i1s1",
      "section": "第（Ⅰ）问",
      "title": "第1步：由 2a+b=0 求 D 坐标",
      "t": 3.5,
      "derive": [
        ["∵", "a＝2，c＝−5，且 2a＋b＝0"],
        ["∴", "b＝−2a＝−4"],
        ["∴", "对称轴 x＝−b/(2a)＝4/4＝1"],
        ["∴", "D 在对称轴与 x 轴的交点，故 D(1, 0)"]
      ],
      "box": ["b＝−4", "对称轴 x＝1", "D(1, 0)"]
    },
    {
      "id": "i1s2",
      "section": "第（Ⅰ）问",
      "title": "第2步：写出解析式",
      "t": 3.5,
      "derive": [
        ["∵", "a＝2，b＝−4，c＝−5"],
        ["∴", "y＝2x²－4x－5"]
      ],
      "box": ["y＝2x²－4x－5"]
    },
    {
      "id": "q1s1",
      "section": "第（Ⅱ）①问",
      "title": "第1步：用全等三角形确定 N 的坐标",
      "t": 3,
      "derive": [
        ["∵", "对称轴恒为 x＝1"],
        ["∴", "D(1,0)"],
        ["作", "MU⊥x轴于 U，NV⊥x轴于 V"],
        ["∵", "M(m,1)"],
        ["∴", "U(m,0)，DU＝m−1，MU＝1"],
        ["∵", "∠MDN＝90°，DM＝DN"],
        ["∴", "Rt△DUM≌Rt△VND"],
        ["∴", "DV＝MU＝1，NV＝DU＝m−1"],
        ["∵", "N 在第四象限"],
        ["∴", "V(2,0)，N(2,1−m)"]
      ],
      "box": ["D(1,0)", "N＝(2,1−m)"]
    },
    {
      "id": "q1s2",
      "section": "第（Ⅱ）①问",
      "title": "第2步：求 m、M、N 与抛物线解析式",
      "t": 3,
      "derive": [
        ["∵", "△DMN 是等腰直角三角形"],
        ["∴", "MN＝√2·DM"],
        ["∵", "MN＝√10"],
        ["∴", "DM＝√5"],
        ["∴", "DM²＝(m−1)²＋1＝5"],
        ["∵", "m＞2"],
        ["∴", "m＝3"],
        ["∴", "M(3,1)，N(2,−2)"],
        ["∵", "N(2,−2) 在抛物线上"],
        ["∴", "4a＋2b＋c＝−2"],
        ["∵", "2a＋b＝0"],
        ["∴", "b＝−2a，c＝−2"],
        ["∵", "M(3,1) 在抛物线上"],
        ["∴", "9a＋3b−2＝1"],
        ["∴", "a＝1，b＝−2"],
        ["∴", "y＝x²−2x−2"]
      ],
      "box": ["m＝3", "M(3,1)，N(2,−2)", "y＝x²−2x−2"]
    },
    {
      "id": "q1s3",
      "section": "第（Ⅱ）①问",
      "title": "第3步：把两动点问题转化为单动点问题（EG+FG→DG+FG）",
      "t": 3,
      "derive": [
        ["作", "GH⊥DN 于 H，GK⊥DM 于 K"],
        ["∵", "△DMN 是等腰直角三角形，G 在 MN 上"],
        ["∴", "△GNH 是等腰直角三角形"],
        ["∴", "GH＝NH＝NG/√2"],
        ["∵", "四边形 DKGH 是矩形"],
        ["∴", "DK＝GH，GK＝DH"],
        ["∵", "DE＝√2·NG＝2GH"],
        ["∴", "EK＝DE−DK＝GH＝DK"],
        ["∵", "GK⊥DM，D、E、K 在 DM 上"],
        ["∴", "GK 垂直平分 DE"],
        ["∴", "△DGE 为等腰三角形，EG＝DG"],
        ["∴", "EG＋FG＝DG＋FG"]
      ],
      "box": ["EG＝DG", "EG＋FG＝DG＋FG"],
      "localControls": {
        "values": { "s": 0.666667 },
        "note": "拖动任一动点组件，另一个会按 DE＝√2·NG 自动联动。",
        "controls": [
          { "var": "s", "label": "动点 E：DE/DM", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 },
          { "var": "s", "label": "动点 G：NG/MN", "min": 0, "max": 0.5, "step": 0.005, "scale": 0.5, "precision": 2 }
        ]
      }
    },
    {
      "id": "q1s4",
      "section": "第（Ⅱ）①问",
      "title": "第4步：用将军饮马求最小值（DG+FG→D'G+FG）并合并答案",
      "t": 3,
      "derive": [
        ["作", "以 DM、DN 为邻边的正方形 DMD′N"],
        ["∵", "MN 是正方形的对角线"],
        ["∴", "D 与 D′ 关于 MN 对称"],
        ["∵", "G 在 MN 上"],
        ["∴", "DG＝D′G"],
        ["∴", "EG＋FG＝DG＋FG＝D′G＋FG≥D′F"],
        ["∵", "DM＝DN＝√5，F 是 DN 中点"],
        ["∴", "D′N＝√5，NF＝√5/2，且 D′N⊥DN"],
        ["∴", "D′F＝√[(√5)²＋(√5/2)²]＝5/2"],
        ["∴", "EG＋FG 的最小值为 5/2"],
        ["∴", "y＝x²−2x−2；最小值＝5/2"]
      ],
      "box": ["y＝x²−2x−2", "最小 EG＋FG＝5/2"],
      "localControls": {
        "values": { "u": 0.333333 },
        "note": "拖动 G 观察：D′、G、F 三点共线时，D′G＋FG 最短。",
        "controls": [
          { "var": "u", "label": "动点 G：NG/MN", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 }
        ]
      }
    },
    {
      "id": "q2s1",
      "section": "第（Ⅱ）②问",
      "title": "第1步：由最小值 5√10/2 求 m 及解析式",
      "t": 8,
      "derive": [
        ["∵", "构造正方形 DMD′N 后，最小 EG＋FG＝D′F"],
        ["∵", "F 是 DN 中点"],
        ["∴", "D′F＝(√5/2)·DM"],
        ["∵", "DM＝√[(m−1)²＋1]＝√(m²−2m＋2)"],
        ["∴", "最小 EG＋FG＝(√5/2)·√(m²−2m＋2)"],
        ["∵", "最小值为 5√10/2"],
        ["∴", "√(m²−2m＋2)＝√10"],
        ["∴", "m²−2m＋2＝10 → m²−2m−48＝0"],
        ["∴", "(m−8)(m+6)＝0"],
        ["∵", "m＞2"],
        ["∴", "m＝8"],
        ["∴", "a＝1/6，b＝−1/3，c＝−7"],
        ["∴", "y＝(1/6)x²－(1/3)x－7"]
      ],
      "box": ["m＝8", "a＝1/6，b＝−1/3，c＝−7", "y＝(1/6)x²－(1/3)x－7"]
    },
    {
      "id": "q2s2",
      "section": "第（Ⅱ）②问",
      "title": "第2步：求 G 的坐标",
      "t": 8,
      "derive": [
        ["∵", "m＝8"],
        ["∴", "M(8,1)，N(2,−7)，F(3/2,−7/2)"],
        ["∵", "正方形 DMD′N 中 MD′∥DN，ND′∥DM"],
        ["∴", "D′(9,−6)"],
        ["∵", "最短时 D′、G、F 三点共线"],
        ["∴", "G 是直线 MN 与直线 D′F 的交点"],
        ["∵", "MN 过 N(2,−7)、M(8,1)"],
        ["∴", "直线 MN：y＋7＝(4/3)(x−2)"],
        ["∴", "y＝(4/3)x−29/3"],
        ["∵", "D′F 过 D′(9,−6)、F(3/2,−7/2)"],
        ["∴", "直线 D′F：y＋6＝−(1/3)(x−9)"],
        ["∴", "y＝−x/3−3"],
        ["∴", "(4/3)x−29/3＝−x/3−3"],
        ["∴", "x＝4，y＝−13/3"],
        ["∴", "G＝(4, −13/3)"],
        ["∴", "解析式为 y＝(1/6)x²−(1/3)x−7，G(4,−13/3)"]
      ],
      "box": ["G(4, −13/3)"]
    }
  ],
