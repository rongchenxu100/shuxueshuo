  "steps": [
    {
      "id": "i1s1",
      "section": "第（Ⅰ）问",
      "title": "第1步：代入 A 求出 b",
      "t": 4,
      "derive": [
        ["∵", "A(−2,0) 在 y＝1/4x²＋bx−4 上"],
        ["∴", "0＝1/4·(−2)²−2b−4"],
        ["∴", "0＝1−2b−4"],
        ["∴", "b＝−3/2"],
        ["∴", "抛物线为 y＝1/4x²−3/2x−4"]
      ],
      "box": ["y＝1/4x²−3/2x−4"]
    },
    {
      "id": "i1s2",
      "section": "第（Ⅰ）问",
      "title": "第2步：配方读出顶点 D",
      "t": 4,
      "derive": [
        ["∵", "y＝1/4x²−3/2x−4"],
        ["∴", "y＝1/4(x−3)²−25/4"],
        ["∴", "顶点 D(3,−25/4)"]
      ],
      "box": ["D(3,−25/4)"]
    },
    {
      "id": "q1s1",
      "section": "第（Ⅱ）问",
      "title": "第1步：设 P，写出旋转后的 Q",
      "t": 4,
      "derive": [
        ["∵", "抛物线对称轴为 x＝3"],
        ["∴", "设 P(3,p)"],
        ["∵", "B(8,0)"],
        ["∴", "从 P 到 B：向右 5，向下 p"],
        ["∵", "BP 绕 P 逆时针旋转 90°"],
        ["∴", "原来向右 5，旋转后变成向上 5"],
        ["∴", "原来向下 p，旋转后变成向右 p"],
        ["∴", "所以 Q 相对 P 的横向、纵向距离为 p，5"],
        ["∴", "Q(3＋p,p＋5)"]
      ],
      "box": ["P(3,p)", "Q(3＋p,p＋5)"]
    },
    {
      "id": "q1s2",
      "section": "第（Ⅱ）问",
      "title": "第2步：代入抛物线求 P",
      "t": 4,
      "derive": [
        ["∵", "Q(3＋p,p＋5) 在 y＝1/4x²−3/2x−4 上"],
        ["∴", "p＋5＝1/4(3＋p)²−3/2(3＋p)−4"],
        ["∴", "p＋5＝1/4p²−25/4"],
        ["∴", "p²−4p−45＝0"],
        ["∴", "(p−9)(p＋5)＝0"],
        ["∴", "p＝9 或 p＝−5"],
        ["∴", "P(3,9) 或 P(3,−5)"]
      ],
      "box": ["P(3,9) 或 P(3,−5)"]
    },
    {
      "id": "q2s1",
      "section": "第（Ⅲ）问",
      "title": "第1步：设 H 在线段 BC 上",
      "t": 4,
      "derive": [
        ["∵", "B(8,0)，C(0,−4)"],
        ["设", "H 在线段 BC 上运动，横坐标为 x"],
        ["∵", "H 在线段 BC 上"],
        ["∴", "0≤x≤8"]
      ],
      "box": ["H 在线段 BC 上", "0≤x≤8"],
      "localControls": {
        "values": { "h": 4 },
        "note": "拖动 H，观察它始终在线段 BC 上。",
        "controls": [
          { "var": "h", "label": "动点 H：横坐标", "min": 0, "max": 8, "step": 0.01, "precision": 2 }
        ]
      }
    },
    {
      "id": "q2s2",
      "section": "第（Ⅲ）问",
      "title": "第2步：构造等腰直角三角形，转化 √2BH",
      "t": 4,
      "derive": [
        ["作", "过 B 作直线 ℓ，使 ℓ 与 BC 成 45°；过 H 作 HR⊥ℓ，垂足为 R"],
        ["∵", "H 在 BC 上，R 在 ℓ 上"],
        ["∴", "∠HBR＝45°"],
        ["∵", "HR⊥ℓ"],
        ["∴", "∠BRH＝90°"],
        ["∴", "△BHR 是等腰直角三角形，BR＝HR"],
        ["∵", "BH 是 Rt△BHR 的斜边"],
        ["∴", "BH＝√2HR"],
        ["∴", "√2BH＝2HR"],
        ["∴", "2AH＋√2BH＝2(AH＋HR)"]
      ],
      "box": ["√2BH＝2HR", "2AH＋√2BH＝2(AH＋HR)"],
      "localControls": {
        "values": { "h": 4 },
        "note": "拖动 H，R 会保持 △BHR 为等腰直角三角形。",
        "controls": [
          { "var": "h", "label": "动点 H：横坐标", "min": 0, "max": 8, "step": 0.01, "precision": 2 }
        ]
      }
    },
    {
      "id": "q2s3",
      "section": "第（Ⅲ）问",
      "title": "第3步：A、H、R三点共线时线段最短",
      "t": 4,
      "derive": [
        ["∵", "直线 ℓ 过定点 B，且与 BC 成 45°"],
        ["∴", "点 R 在固定直线 ℓ 上运动"],
        ["∵", "两点之间线段最短"],
        ["∴", "AH＋HR≥AR"],
        ["∵", "R 在定直线 ℓ 上"],
        ["∴", "AR 的最小值是 A 到 ℓ 的垂线段"],
        ["∴", "最短时 A、H、R 三点共线，且 AR⊥ℓ"]
      ],
      "box": ["AH＋HR≥AR", "最短时：A、H、R 共线，且 AR⊥ℓ"],
      "localControls": {
        "values": { "h": 4 },
        "note": "拖动 H，观察折线 A-H-R 被拉直时的状态。",
        "controls": [
          { "var": "h", "label": "动点 H：横坐标", "min": 0, "max": 8, "step": 0.01, "precision": 2 }
        ]
      }
    },
    {
      "id": "q2s4",
      "section": "第（Ⅲ）问",
      "title": "第4步：用等腰直角三角形求最小值",
      "t": 4,
      "derive": [
        ["作", "连接 AC"],
        ["∵", "AC²＋BC²＝20＋80＝100＝AB²"],
        ["∴", "AC⊥BC"],
        ["∵", "ℓ 与 BC 成 45°，且最短时 AR⊥ℓ"],
        ["∴", "∠CAH＝45°"],
        ["∴", "△ACH 是等腰直角三角形"],
        ["∴", "CH＝AC＝2√5，AH＝2√10"],
        ["∵", "BC＝4√5"],
        ["∴", "BH＝BC−CH＝2√5"],
        ["∵", "△BHR 是等腰直角三角形"],
        ["∴", "HR＝BH/√2＝√10"],
        ["∴", "AR＝AH＋HR＝3√10"],
        ["∵", "CH＝1/2BC"],
        ["∴", "H(4,−2)"],
        ["∴", "H 在线段 BC 上"],
        ["∴", "2AH＋√2BH 的最小值为 2AR＝6√10"]
      ],
      "box": ["H(4,−2)", "最小值：6√10"]
    }
