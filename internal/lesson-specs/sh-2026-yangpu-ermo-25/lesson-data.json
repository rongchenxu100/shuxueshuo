  "steps": [
    {
      "id": "q1s1",
      "section": "第（1）问",
      "title": "第1步：由对折的中垂线性质得 AH = BH",
      "t": 0.5,
      "derive": [
        ["∵", "对折正方形 ABCD（图 2），EF 是中线"],
        ["∴", "AE = BE，EF ⊥ AB（EF 是 AB 的中垂线）"],
        ["∵", "H 在 EF 上"],
        ["∴", "AH = BH"]
      ],
      "box": [
        "EF 是 AB 的中垂线",
        "AH = BH"
      ]
    },
    {
      "id": "q1s2",
      "section": "第（1）问",
      "title": "第2步：由折叠 △ABG ≅ △HBG 得 BA = BH",
      "t": 0.5,
      "derive": [
        ["∵", "沿 BG 折叠把 △ABG 翻到 △HBG（A → H）"],
        ["∴", "△ABG ≅ △HBG"],
        ["∴", "BA = BH，∠ABG = ∠HBG = ½∠ABH"]
      ],
      "box": [
        "△ABG ≅ △HBG",
        "BA = BH",
        "∠ABG = ½∠ABH"
      ]
    },
    {
      "id": "q1s3",
      "section": "第（1）问",
      "title": "第3步：由三段相等证 △ABH 等边，求 ∠ABG",
      "t": 0.5,
      "derive": [
        ["∵", "AH = BH（Step 1），BA = BH（Step 2）"],
        ["∴", "AH = BH = BA"],
        ["∴", "△ABH 是等边三角形"],
        ["∴", "∠ABH = 60°"],
        ["∵", "∠ABG = ½∠ABH"],
        ["∴", "∠ABG = 30°"]
      ],
      "box": [
        "△ABH 是等边三角形",
        "∠ABH = 60°",
        "∠ABG = 30°（最终答案）"
      ]
    },
    {
      "id": "q2s1",
      "section": "第（2）问",
      "title": "第1步：由对折得 ∠ACB = ∠ACD = 45°",
      "t": 0.41421356,
      "derive": [
        ["∵", "沿 AC 对折正方形 ABCD（图 5）"],
        ["∴", "△ABC ≅ △ADC"],
        ["∴", "∠ACB = ∠ACD = ½∠BCD = 45°"]
      ],
      "box": [
        "∠ACB = ∠ACD = 45°"
      ]
    },
    {
      "id": "q2s2",
      "section": "第（2）问",
      "title": "第2步：列出两次折叠产生的全等与等角关系",
      "t": 0.41421356,
      "derive": [
        ["∵", "把 AB 折至 BF（图 6，折痕 BE）"],
        ["∴", "△ABE ≅ △FBE"],
        ["∴", "∠ABE = ∠FBE，∠BAE = ∠BFE = 90°，BA = BF"],
        ["∵", "把 BC 折至 BF（图 7，折痕 BG）"],
        ["∴", "△CBG ≅ △FBG"],
        ["∴", "∠CBG = ∠FBG，∠BCG = ∠BFG = 90°，BC = BF"]
      ],
      "box": [
        "△ABE ≅ △FBE",
        "△CBG ≅ △FBG",
        "F 处：∠BFE = ∠BFG = 90°",
        "BF = BA = BC"
      ]
    },
    {
      "id": "q2s3",
      "section": "第（2）问",
      "title": "第3步：由 F 处两个直角证 E、F、G 三点共线",
      "t": 0.41421356,
      "derive": [
        ["∵", "∠BFE = 90°"],
        ["∴", "FE ⊥ BF"],
        ["∵", "∠BFG = 90°"],
        ["∴", "FG ⊥ BF"],
        ["∵", "过定点 F、垂直于定直线 BF 的直线只有一条"],
        ["∴", "直线 FE 与直线 FG 是同一条"],
        ["∴", "E、F、G 三点共线"]
      ],
      "box": [
        "∠BFE + ∠BFG = 180°",
        "E、F、G 三点共线",
        "F 在线段 EG 上"
      ]
    },
    {
      "id": "q2s4",
      "section": "第（2）问",
      "title": "第4步：由 ∠ABC = 90° 拆分证 ∠EBG = 45°",
      "t": 0.41421356,
      "derive": [
        ["∵", "设 ∠ABE = ∠FBE = α，∠CBG = ∠FBG = β"],
        ["∵", "∠ABC = ∠ABE + ∠EBF + ∠FBG + ∠GBC = 2(α + β)"],
        ["∵", "∠ABC = 90°"],
        ["∴", "α + β = 45°"],
        ["∵", "∠EBG = α + β"],
        ["∴", "∠EBG = 45°"]
      ],
      "box": [
        "α + β = 45°",
        "∠EBG = 45°"
      ]
    },
    {
      "id": "q2s5",
      "section": "第（2）问",
      "title": "第5步：由 AA 相似得 △BQH ∽ △CQG",
      "t": 0.41421356,
      "derive": [
        ["∵", "H 在射线 BE 上 ⇒ 射线 BH = 射线 BE"],
        ["∵", "Q 在射线 BG 上 ⇒ 射线 BQ = 射线 BG"],
        ["∴", "∠QBH = ∠EBG = 45°"],
        ["∵", "Q 在 AC 上 ⇒ 射线 CQ = 射线 CA；G 在 CD 上 ⇒ 射线 CG = 射线 CD"],
        ["∴", "∠QCG = ∠ACD = 45°"],
        ["∴", "∠QBH = 45° = ∠QCG"],
        ["∵", "∠BQH = ∠CQG（对顶角）"],
        ["∴", "△BQH ∽ △CQG（AA）"],
        ["∴", "BQ/CQ = HQ/GQ"]
      ],
      "box": [
        "△BQH ∽ △CQG",
        "BQ/CQ = HQ/GQ"
      ]
    },
    {
      "id": "q2s6",
      "section": "第（2）问",
      "title": "第6步：由比例换边得 △BQC ∽ △HQG，证 ∠BHG = 90°",
      "t": 0.41421356,
      "derive": [
        ["∵", "BQ/CQ = HQ/GQ ⇒ BQ/HQ = CQ/GQ"],
        ["∵", "∠BQC = ∠HQG（对顶角）"],
        ["∴", "△BQC ∽ △HQG（SAS）"],
        ["∴", "∠BCQ = ∠HGQ"],
        ["∵", "∠BCQ = ∠ACB = 45°"],
        ["∴", "∠HGQ = 45°"],
        ["∵", "B、Q、G 共线 ⇒ 射线 GQ = 射线 GB"],
        ["∴", "∠HGB = ∠HGQ = 45°"],
        ["∵", "在 △BHG 中 ∠HBG + ∠HGB + ∠BHG = 180°"],
        ["∴", "∠BHG = 180° − 45° − 45° = 90°"]
      ],
      "box": [
        "△BQC ∽ △HQG",
        "∠HGB = 45°",
        "∠BHG = 90°"
      ]
    },
    {
      "id": "q2s7",
      "section": "第（2）问",
      "title": "第7步：由 Rt△BHG 与对称的 Rt△BQE 得 BH/BG = BQ/BE = √2/2",
      "t": 0.41421356,
      "derive": [
        ["∵", "在 Rt△BHG 中 ∠BHG = 90°、∠HBG = 45°"],
        ["∴", "BH/BG = cos 45° = √2/2"],
        ["∵", "△BQE 与 △BHG 的对称配置（A↔C、E↔G、H↔Q）"],
        ["∴", "用平行推理可得 ∠BQE = 90°"],
        ["∴", "Rt△BQE 中 BQ/BE = cos 45° = √2/2"]
      ],
      "box": [
        "BH/BG = √2/2",
        "BQ/BE = √2/2"
      ]
    },
    {
      "id": "q2s8",
      "section": "第（2）问",
      "title": "第8步：由 SAS 得 △BQH ∽ △BEG，求 HQ/GE",
      "t": 0.41421356,
      "derive": [
        ["∵", "BH/BG = BQ/BE = √2/2"],
        ["∵", "∠QBH = ∠EBG（公共角）"],
        ["∴", "△BQH ∽ △BEG（SAS）"],
        ["∴", "HQ/GE = BH/BG = √2/2"]
      ],
      "box": [
        "△BQH ∽ △BEG",
        "HQ/GE = √2/2（最终答案）"
      ]
    },
    {
      "id": "q3s1",
      "section": "第（3）问",
      "title": "第1步：设 CG = n，由折叠得 EG = m + n",
      "t": 0.41421356,
      "derive": [
        ["∵", "设 CG = n，正方形 ABCD 边长为 1"],
        ["∴", "DG = 1 − n"],
        ["∵", "折叠后 E、F、G 共线，EF = AE = m，FG = CG = n（折叠保距）"],
        ["∴", "EG = EF + FG = m + n"]
      ],
      "box": [
        "DG = 1 − n",
        "EG = m + n（= AE + CG）"
      ]
    },
    {
      "id": "q3s2",
      "section": "第（3）问",
      "title": "第2步：在 Rt△DEG 中由勾股定理求 n",
      "t": 0.41421356,
      "derive": [
        ["∵", "E 在 AD 上、AE = m"],
        ["∴", "DE = 1 − m"],
        ["∵", "∠EDG = 90°（正方形角）"],
        ["∴", "Rt△DEG 中 DE² + DG² = EG²"],
        ["∴", "(1 − m)² + (1 − n)² = (m + n)²"],
        ["∴", "2 − 2m − 2n = 2mn"],
        ["∴", "n(1 + m) = 1 − m"],
        ["∴", "n = (1 − m) / (1 + m)"]
      ],
      "box": [
        "n = (1 − m) / (1 + m)"
      ]
    },
    {
      "id": "q3s3",
      "section": "第（3）问",
      "title": "第3步：由（2）问结论求 HQ",
      "t": 0.41421356,
      "derive": [
        ["∵", "HQ/GE = √2/2（第（2）问 Step 8）"],
        ["∴", "HQ = (√2/2) · GE = (√2/2) · (m + n)"],
        ["∵", "m + n = (1 + m²) / (1 + m)"],
        ["∴", "HQ = (√2/2) · (1 + m²) / (1 + m)"]
      ],
      "box": [
        "HQ = (√2/2) · (1 + m²) / (1 + m)"
      ]
    },
    {
      "id": "q3s4",
      "section": "第（3）问",
      "title": "第4步：由 AB ∥ CD 平行截比求 QC",
      "t": 0.41421356,
      "derive": [
        ["∵", "AB ∥ CD（正方形对边）"],
        ["∴", "CG/AB = QC/QA（平行线分线段成比例）"],
        ["∴", "由合比定理 CG/(CG + AB) = QC/(QC + QA) = QC/AC"],
        ["∵", "AC = √2，AB = 1，CG = n"],
        ["∴", "n/(1 + n) = QC/√2"],
        ["∵", "1 + n = 2/(1 + m)，所以 n/(1 + n) = (1 − m)/2"],
        ["∴", "QC = √2 · (1 − m)/2 = (√2/2) · (1 − m)"]
      ],
      "box": [
        "QC = (√2/2) · (1 − m)"
      ]
    },
    {
      "id": "q3s5",
      "section": "第（3）问",
      "title": "第5步：合并得 HQ/QC",
      "t": 0.41421356,
      "derive": [
        ["∵", "HQ = (√2/2) · (1 + m²) / (1 + m)"],
        ["∵", "QC = (√2/2) · (1 − m)"],
        ["∴", "HQ/QC = [(1 + m²)/(1 + m)] / (1 − m)"],
        ["∴", "HQ/QC = (1 + m²) / [(1 + m)(1 − m)]"],
        ["∴", "HQ/QC = (1 + m²) / (1 − m²)"]
      ],
      "box": [
        "HQ = (√2/2)(1 + m²)/(1 + m)",
        "QC = (√2/2)(1 − m)",
        "HQ/QC = (1 + m²) / (1 − m²)（最终答案）"
      ]
    }
  ],
