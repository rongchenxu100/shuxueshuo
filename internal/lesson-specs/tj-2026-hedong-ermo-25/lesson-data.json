  "problem": {
    "summary": "第 25 题（2026 天津市河东区二模）二次函数综合：顶点、反射最短路与 HF 最小值反求 a。",
    "lines": [
      { "text": "（25）（本小题 10 分）如图，抛物线 y＝ax²＋bx＋c（a，b，c 为常数，a≠0）的顶点为 P，与 x 轴交于 A，B 两点（点 A 在点 B 的左侧），与 y 轴交于点 C。" },
      { "text": "（Ⅰ）若 a＝−1。" },
      { "text": "① 当 b＝4，c＝−3 时，求点 P 的坐标；", "answerId": "answerI1", "answer": "P(2,1)" },
      { "text": "② 点 A(−2,0)，C(0,2)，点 D 在抛物线上，∠CAD＝90°，点 G 在 AD 上，当 △BCG 的周长最小时，求出点 G 的坐标；", "answerId": "answerI2", "answer": "G(−8/7, −6/7)" },
      { "text": "（Ⅱ）a＞0，点 O 为原点，OB＝OC，点 E 在线段 BC 上，BC＝4BE，点 F 在抛物线上，OE⊥OF，且 OE＝OF，又点 H 是第四象限的一动点，满足 ∠OHB＝90°，连接 HF，当 HF 的最小值为 3√2−2 时，求 a 的值。", "answerId": "answerII", "answer": "a＝2/5 或 a＝2(√10−2)/(3√2−2)" }
    ]
  },
  "ui": {
    "legend": [
      { "colorVar": "paper", "label": "抛物线与坐标点" },
      { "colorVar": "fold", "label": "构造线段与最短路径" }
    ],
    "sliderLabel": "参数 m",
    "paramLabelPrefix": "m=",
    "goToProblemMode": "doubleScroll",
    "groupTitles": {
      "第（Ⅰ）①问": "第（Ⅰ）①  求顶点 P",
      "第（Ⅰ）②问": "第（Ⅰ）②  反射最短求 G",
      "第（Ⅱ）问": "第（Ⅱ）  最小值反求 a"
    }
  },
  "steps": [
    {
      "id": "i1s1",
      "section": "第（Ⅰ）①问",
      "title": "第1步：配方求顶点 P",
      "t": 4,
      "derive": [
        ["∵", "a＝−1，b＝4，c＝−3"],
        ["∴", "y＝−x²＋4x−3"],
        ["∴", "y＝−(x−2)²＋1"],
        ["∴", "顶点 P(2,1)"]
      ],
      "box": ["P(2,1)"]
    },
    {
      "id": "i2s1",
      "section": "第（Ⅰ）②问",
      "title": "第1步：由 A、C 化简函数表达式，求 B",
      "t": 4,
      "derive": [
        ["∵", "a＝−1，C(0,2)"],
        ["∴", "y＝−x²＋bx＋2"],
        ["∵", "A(−2,0) 在抛物线上"],
        ["∴", "0＝−4−2b＋2"],
        ["∴", "b＝−1"],
        ["∴", "y＝−x²−x＋2＝−(x＋2)(x−1)"],
        ["∴", "另一个交点 B(1,0)"]
      ],
      "box": ["y＝−(x＋2)(x−1)", "B(1,0)"]
    },
    {
      "id": "i2s2",
      "section": "第（Ⅰ）②问",
      "title": "第2步：由垂直关系确定 D",
      "t": 4,
      "derive": [
        ["∵", "A(−2,0)，C(0,2)"],
        ["∴", "直线 AC 与 x 轴成 45°"],
        ["∵", "∠CAD＝90°"],
        ["∴", "AD 的方向为向右下的 45°"],
        ["∴", "直线 AD：y＝−x−2"],
        ["∵", "D 在抛物线 y＝−x²−x＋2 上"],
        ["∴", "−x²−x＋2＝−x−2"],
        ["∴", "x²＝4"],
        ["∵", "x＝−2 对应点 A"],
        ["∴", "D(2,−4)"]
      ],
      "box": ["AD：y＝−x−2", "D(2,−4)"]
    },
    {
      "id": "i2s3",
      "section": "第（Ⅰ）②问",
      "title": "第3步：将军饮马求解最小值",
      "t": 4,
      "derive": [
        ["∵", "△BCG 的周长＝BC＋BG＋CG"],
        ["∵", "BC 是定长"],
        ["∴", "只需使 BG＋CG 最小"],
        ["作", "点 C 关于直线 AD 的对称点 C′"],
        ["∵", "AD：x＋y＋2＝0，C(0,2)"],
        ["∴", "C′(−4,−2)"],
        ["∵", "G 在 AD 上"],
        ["∴", "CG＝C′G"],
        ["∴", "BG＋CG＝BG＋C′G≥BC′"],
        ["∴", "当 B、G、C′ 三点共线时取最小"],
        ["∵", "直线 BC′：y＝2/5(x−1)"],
        ["∵", "直线 AD：y＝−x−2"],
        ["∴", "G(−8/7,−6/7)"]
      ],
      "box": ["最短时：B、G、C′ 三点共线", "G(−8/7, −6/7)"],
      "localControls": {
        "values": { "u": 0.214286 },
        "note": "拖动 G，观察 BG＋CG 与 BG＋C′G 的对应变化。",
        "controls": [
          { "var": "u", "label": "动点 G：AG/AD", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 }
        ]
      }
    },
    {
      "id": "q1s1",
      "section": "第（Ⅱ）问",
      "title": "第1步：设 m 表示 B、C，并写出抛物线",
      "t": 4,
      "derive": [
        ["设", "OB＝OC＝m，m＞0"],
        ["∵", "B 在 x 轴正半轴"],
        ["∴", "B(m,0)"],
        ["∵", "C 在 y 轴上，且 OC＝m"],
        ["∴", "C(0,−m) 或 C(0,m)"],
        ["先看", "C(0,−m)，此时 c＝−m"],
        ["∵", "B(m,0) 是一个 x 轴交点，常数项为 −m"],
        ["∴", "y＝a(x−m)(x＋1/a)"],
        ["∴", "y＝ax²＋(1−am)x−m"]
      ],
      "box": ["B(m,0)", "C(0,−m)", "y＝ax²＋(1−am)x−m"]
    },
    {
      "id": "q1s2",
      "section": "第（Ⅱ）问",
      "title": "第2步：由 BC＝4BE 求 E",
      "t": 4,
      "derive": [
        ["∵", "BC＝4BE"],
        ["∴", "BE＝1/4 BC"],
        ["∵", "E 在线段 BC 上"],
        ["∴", "E 从 B 向 C 走了 1/4 个 BC"],
        ["∴", "E(3m/4,−m/4)"]
      ],
      "box": ["E(3m/4, −m/4)"]
    },
    {
      "id": "q1s3",
      "section": "第（Ⅱ）问",
      "title": "第3步：由 OE⊥OF 且 OE＝OF 定 F",
      "t": 4,
      "derive": [
        ["∵", "OE⊥OF，且 OE＝OF"],
        ["作", "过 E 作 x 轴垂线，过 F 作 y 轴垂线"],
        ["∵", "E(3m/4,−m/4)"],
        ["∴", "由两个全等直角三角形读出 F(−m/4,−3m/4)"]
      ],
      "box": ["F(−m/4, −3m/4)"]
    },
    {
      "id": "q1s4",
      "section": "第（Ⅱ）问",
      "title": "第4步：代入 F 得到 am 关系",
      "t": 4,
      "derive": [
        ["∵", "F(−m/4,−3m/4) 在抛物线 y＝ax²＋(1−am)x−m 上"],
        ["∴", "−3m/4＝a·m²/16＋(1−am)(−m/4)−m"],
        ["∴", "−3m/4＝5am²/16−5m/4"],
        ["∵", "m＞0"],
        ["∴", "5am＝8"]
      ],
      "box": ["5am＝8"]
    },
    {
      "id": "q1s5",
      "section": "第（Ⅱ）问",
      "title": "第5步：C 在下半轴时的隐圆最短模型",
      "t": 4,
      "derive": [
        ["∵", "∠OHB＝90°"],
        ["∴", "H 在以 OB 为直径的圆上"],
        ["∴", "拖动 H 可观察它在下半圆上运动"],
        ["∴", "圆心 K(m/2,0)，半径 m/2"],
        ["∵", "F(−m/4,−3m/4)"],
        ["∴", "FK＝√((3m/4)²＋(3m/4)²)"],
        ["∴", "FK＝3√2m/4"],
        ["∴", "HF 的最小值＝FK−m/2"],
        ["∴", "HFmin＝(3√2−2)m/4"],
        ["∵", "HF 的最小值为 3√2−2"],
        ["∴", "m＝4"],
        ["∵", "5am＝8"],
        ["∴", "a＝2/5"]
      ],
      "box": ["C(0,−m)：a＝2/5"],
      "localControls": {
        "values": { "u": 0.75 },
        "note": "拖动 H，观察 HF 在圆弧上变化，最短时 F、H、K 共线。",
        "controls": [
          { "var": "u", "label": "动点 H：圆弧位置", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 }
        ]
      }
    },
    {
      "id": "q1s6",
      "section": "第（Ⅱ）问",
      "title": "第6步：C 在上半轴时的隐圆最短模型",
      "t": 7.7180892792670335,
      "derive": [
        ["若", "C 在 y 轴上半轴，则 C(0,m)"],
        ["∴", "E(3m/4,m/4)"],
        ["∵", "OE⊥OF，且 OE＝OF，F 在第四象限"],
        ["∴", "F(m/4,−3m/4)"],
        ["∵", "y＝a(x−m)(x−1/a)＝ax²−(am＋1)x＋m"],
        ["∵", "F 在抛物线上"],
        ["∴", "−3m/4＝a·m²/16−(am＋1)m/4＋m"],
        ["∴", "am＝8"],
        ["∵", "同一个隐圆：圆心 K(m/2,0)，半径 m/2"],
        ["∴", "FK＝√((m/4)²＋(3m/4)²)＝√10m/4"],
        ["∴", "HFmin＝(√10−2)m/4"],
        ["∵", "HF 的最小值为 3√2−2"],
        ["∴", "m＝4(3√2−2)/(√10−2)"],
        ["∴", "a＝8/m＝2(√10−2)/(3√2−2)"]
      ],
      "box": ["C(0,m)：a＝2(√10−2)/(3√2−2)"],
      "localControls": {
        "values": { "u": 0.602416 },
        "note": "拖动 H，观察上半轴情形下同一个隐圆最短模型。",
        "controls": [
          { "var": "u", "label": "动点 H：圆弧位置", "min": 0, "max": 1, "step": 0.01, "scale": 1, "precision": 2 }
        ]
      }
    },
    {
      "id": "q1s7",
      "section": "第（Ⅱ）问",
      "title": "第7步：汇总两种位置的 a",
      "t": 4,
      "derive": [
        ["∵", "C 在 y 轴下半轴时", { "refStep": "q1s5", "refLabel": "回看下半轴情形" }],
        ["∴", "a＝2/5"],
        ["∵", "C 在 y 轴上半轴时", { "refStep": "q1s6", "refLabel": "回看上半轴情形" }],
        ["∴", "a＝2(√10−2)/(3√2−2)"]
      ],
      "box": ["a＝2/5", "或 a＝2(√10−2)/(3√2−2)"]
    }
  ],
