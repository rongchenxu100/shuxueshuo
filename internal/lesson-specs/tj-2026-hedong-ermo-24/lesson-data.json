        { "id": "originalFigure1", "title": "图 1", "ariaLabel": "图 1：t=0 时的折叠示意" },
        { "id": "originalFigure2", "title": "图 2", "ariaLabel": "图 2：重合部分为五边形时的折叠示意" }
      ] }
