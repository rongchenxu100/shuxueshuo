  "steps": [
    {
      "id": "q1s1",
      "section": "第（Ⅰ）问",
      "title": "第1步：由正方形边长求 AB",
      "t": 0,
      "derive": [
        ["∵", "OABC 是正方形，O(0,0)，B(4,4)"],
        ["∴", "A(4,0)，C(0,4)"],
        ["∴", "AB=4"]
      ],
      "box": ["AB=4"]
    },
    {
      "id": "q1s2",
      "section": "第（Ⅰ）问",
      "title": "第2步：由 30° 直线求 AE",
      "t": 0,
      "derive": [
        ["∵", "t=0"],
        ["∴", "D 与 O 重合，D(0,0)"],
        ["∵", "∠EDC=60°，DC 竖直向上"],
        ["∴", "DE 与 x 轴正方向夹角为 30°"],
        ["∵", "E 在 x=4 上"],
        ["∴", "E 的纵坐标为 4tan30°=4√3/3"],
        ["∴", "AE=4√3/3"]
      ],
      "box": ["E(4,4√3/3)", "AE=4√3/3"]
    },
    {
      "id": "q1s3",
      "section": "第（Ⅰ）问",
      "title": "第3步：由折叠对称求 A′坐标",
      "t": 0,
      "derive": [
        ["∵", "折痕 DE 与 x 轴夹角为 30°"],
        ["∴", "点 A 关于 DE 对称后，DA′ 与 x 轴夹角为 60°"],
        ["∵", "折叠保持长度不变"],
        ["∴", "DA′=DA=4"],
        ["∴", "A′(4cos60°,4sin60°)=(2,2√3)"]
      ],
      "box": ["A′(2,2√3)"]
    },
    {
      "id": "q2s1",
      "section": "第（Ⅱ）问",
      "title": "第1步：由折痕方向表示关键点坐标",
      "t": 1.35,
      "derive": [
        ["∵", "D(0,t)，DE 与 x 轴正方向夹角为 30°"],
        ["∴", "E(4,t+4√3/3)"],
        ["∵", "关于过 D、方向角为 30° 的直线对称"],
        ["∴", "O′(-√3t/2,3t/2)"],
        ["∴", "A′(2-√3t/2,2√3+t/2)"]
      ],
      "box": ["E(4,t+4√3/3)", "O′(-√3t/2,3t/2)", "A′(2-√3t/2,2√3+t/2)"]
    },
    {
      "id": "q2s2",
      "section": "第（Ⅱ）问",
      "title": "第2步：由上边界位置判断五边形范围",
      "t": 1.35,
      "derive": [
        ["∵", "五边形状态开始于 A′ 落到上边 CB"],
        ["∴", "2√3+t/2=4，解得 t=8-4√3"],
        ["∵", "五边形状态结束于 E 落到点 B"],
        ["∴", "t+4√3/3=4，解得 t=4-4√3/3"],
        ["∴", "8-4√3<t<4-4√3/3"]
      ],
      "box": ["左边界：t=8-4√3", "右边界：t=4-4√3/3", "8-4√3<t<4-4√3/3"],
      "minis": [
        { "title": "t=8-4√3", "caption": "A′ 刚到达 CB，五边形尚未形成。", "t": 1.0718 },
        { "title": "五边形阶段", "caption": "G、H 都在 CB 上，顶部出现 GH。", "t": 1.35 },
        { "title": "t=4-4√3/3", "caption": "E 到达 B，五边形阶段结束。", "t": 1.6906 }
      ]
    },
    {
      "id": "q2s3",
      "section": "第（Ⅱ）问",
      "title": "第3步：由直线 O′A′ 求 x_G",
      "t": 1.35,
      "derive": [
        ["∵", "G 在 CB 上"],
        ["∴", "y_G=4"],
        ["∵", "O′(-√3t/2,3t/2)，A′(2-√3t/2,2√3+t/2)"],
        ["∴", "直线 O′A′ 的斜率为 (2√3-t)/2"],
        ["∴", "x_G=-√3t/2+(8-3t)/(2√3-t)"]
      ],
      "box": ["x_G=-√3t/2+(8-3t)/(2√3-t)"]
    },
    {
      "id": "q2s4",
      "section": "第（Ⅱ）问",
      "title": "第4步：由直线 A′E 求 x_H",
      "t": 1.35,
      "derive": [
        ["∵", "H 在 CB 上"],
        ["∴", "y_H=4"],
        ["∵", "A′(2-√3t/2,2√3+t/2)，E(4,t+4√3/3)"],
        ["∴", "从 A′ 到 E 的横向变化为 2+√3t/2，纵向变化为 t/2-2√3/3"],
        ["∴", "x_H=2-√3t/2+((4-2√3-t/2)(2+√3t/2))/(t/2-2√3/3)"]
      ],
      "box": ["x_H=2-√3t/2+((4-2√3-t/2)(2+√3t/2))/(t/2-2√3/3)"]
    },
    {
      "id": "q2s5",
      "section": "第（Ⅱ）问",
      "title": "第5步：由横坐标差求 GH",
      "t": 1.35,
      "derive": [
        ["∵", "G、H 都在 CB 上"],
        ["∴", "GH=x_H-x_G"],
        ["∴", "GH=[-3t^3+(24-12√3)t^2+32t+128√3-256]/[2(4-√3t)(2√3-t)]"],
        ["∵", "8-4√3<t<4-4√3/3"],
        ["∴", "上式对应的线段 GH 为正值"]
      ],
      "box": ["GH=[-3t^3+(24-12√3)t^2+32t+128√3-256]/[2(4-√3t)(2√3-t)]", "8-4√3<t<4-4√3/3"]
    },
    {
      "id": "q3s1",
      "section": "第（Ⅲ）问",
      "title": "第1步：由重合图形变化判断面积阶段",
      "t": 2,
      "derive": [
        ["∵", "t=0 时重合面积大于 2√3"],
        ["∵", "当 E 越过 B 后，重合部分逐渐缩小"],
        ["∴", "面积为 2√3 的解出现在后半段的三角形重合状态中"]
      ],
      "box": ["目标：S=2√3", "只需看后半段三角形重合状态"],
      "minis": [
        { "title": "t=0", "caption": "初始重合面积大于 2√3。", "t": 0 },
        { "title": "五边形阶段", "caption": "重合区域仍大于 2√3。", "t": 1.35 },
        { "title": "t=2", "caption": "后半段三角形面积等于 2√3。", "t": 2 },
        { "title": "t=4", "caption": "重合区域缩小到 0。", "t": 4 }
      ]
    },
    {
      "id": "q3s2",
      "section": "第（Ⅲ）问",
      "title": "第2步：由三角形面积求 t",
      "t": 2,
      "derive": [
        ["∵", "后半段重合区域是直角三角形，竖直直角边为 4-t"],
        ["∵", "斜边方向与 x 轴夹角为 30°"],
        ["∴", "水平直角边为 √3(4-t)"],
        ["∴", "S=1/2·(4-t)·√3(4-t)=√3(4-t)^2/2"],
        ["∵", "S=2√3"],
        ["∴", "(4-t)^2=4"],
        ["∵", "0≤t≤4"],
        ["∴", "t=2"]
      ],
      "box": ["S=√3(4-t)^2/2", "t=2"]
    }
  ],
