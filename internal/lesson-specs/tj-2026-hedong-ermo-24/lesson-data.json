  "steps": [
    {
      "id": "q1s1",
      "section": "第（Ⅰ）问",
      "title": "第1步：由正方形边长求 AB",
      "t": 0,
      "derive": [
        ["∵", "OABC 是正方形，O(0,0)，B(4,4)"],
        ["∴", "A(4,0)，C(0,4)"],
        ["∴", "AB=4"]
      ],
      "box": ["AB=4"]
    },
    {
      "id": "q1s2",
      "section": "第（Ⅰ）问",
      "title": "第2步：由 30° 直线求 AE",
      "t": 0,
      "derive": [
        ["∵", "t=0"],
        ["∴", "D 与 O 重合，D(0,0)"],
        ["∵", "∠EDC=60°，DC 竖直向上"],
        ["∴", "DE 与 x 轴正方向夹角为 30°"],
        ["∵", "E 在 x=4 上"],
        ["∴", "E 的纵坐标为 4tan30°=4√3/3"],
        ["∴", "AE=4√3/3"]
      ],
      "box": ["E(4,4√3/3)", "AE=4√3/3"]
    },
    {
      "id": "q1s3",
      "section": "第（Ⅰ）问",
      "title": "第3步：由直角三角形求 A′坐标",
      "t": 0,
      "derive": [
        ["∵", "折痕 DE 与 x 轴夹角为 30°"],
        ["∴", "点 A 关于 DE 对称后，DA′（即 OA′）与 x 轴夹角为 60°"],
        ["作", "过 A′ 向 OA 作垂线，垂足为 K"],
        ["∵", "折叠保持长度不变"],
        ["∴", "DA′=DA=4"],
        ["∴", "DK=4cos60°=2，A′K=4sin60°=2√3"],
        ["∴", "A′(2,2√3)"]
      ],
      "box": ["A′(2,2√3)"]
    },
    {
      "id": "q2s1",
      "section": "第（Ⅱ）问",
      "title": "第1步：由 30° 直角三角形求 CG",
      "t": 1,
      "derive": [
        ["∵", "折叠保持长度不变，OD=t"],
        ["∴", "O′D=t"],
        ["∵", "在 Rt△O′DF 中，∠O′FD=30°"],
        ["∴", "DF=2O′D=2t"],
        ["∴", "CF=OC-OF=4-3t"],
        ["∵", "在 Rt△CFG 中，∠CFG=30°"],
        ["∴", "CG=CF·tan30°=(4-3t)/√3=4√3/3-√3t"]
      ],
      "box": ["O′D=t", "DF=2t", "CF=4-3t", "CG=4√3/3-√3t"]
    },
    {
      "id": "q2s2",
      "section": "第（Ⅱ）问",
      "title": "第2步：由 30° 直角三角形求 HB",
      "t": 1,
      "derive": [
        ["作", "过 D 向 AB 作垂线，垂足为 K"],
        ["∵", "DK=OA=4，DE 与 DK 的夹角为 30°"],
        ["∴", "在 Rt△DKE 中，EK=DK·tan30°=4√3/3"],
        ["∴", "AE=AK+KE=t+4√3/3"],
        ["∴", "BE=AB-AE=4-t-4√3/3"],
        ["∵", "在 Rt△HBE 中，∠BHE=30°"],
        ["∴", "HB=√3·BE=4√3-4-√3t"]
      ],
      "box": ["EK=4√3/3", "BE=4-t-4√3/3", "HB=4√3-4-√3t"]
    },
    {
      "id": "q2s3",
      "section": "第（Ⅱ）问",
      "title": "第3步：由线段差求 GH",
      "t": 1,
      "derive": [
        ["∵", "G、H 都在 CB 上"],
        ["∴", "GH=BC-CG-HB"],
        ["∴", "GH=4-(4√3/3-√3t)-(4√3-4-√3t)"],
        ["∴", "GH=2√3t+8-16√3/3"]
      ],
      "box": ["CG=4√3/3-√3t", "HB=4√3-4-√3t", "GH=2√3t+8-16√3/3"]
    },
    {
      "id": "q2s4",
      "section": "第（Ⅱ）问",
      "title": "第4步：由边界状态判断 t 范围",
      "t": 1,
      "derive": [
        ["∵", "重合部分为五边形时，G、H 都在 CB 上且 GH>0"],
        ["∵", "GH=2√3t+8-16√3/3"],
        ["∴", "GH>0，解得 t>(8-4√3)/3"],
        ["∵", "右边界为 G 与 C 重合，即 CG=0"],
        ["∴", "4√3/3-√3t=0，解得 t=4/3"],
        ["∴", "(8-4√3)/3<t<4/3"]
      ],
      "box": ["GH>0：t>(8-4√3)/3", "CG>0：t<4/3", "(8-4√3)/3<t<4/3"],
      "minis": [
        { "title": "t=(8-4√3)/3", "caption": "GH=0，五边形尚未形成。", "t": 0.3573 },
        { "title": "五边形阶段", "caption": "G、H 都在 CB 上，顶部出现 GH。", "t": 1 },
        { "title": "t=4/3", "caption": "G 与 C 重合，五边形阶段结束。", "t": 1.3333 }
      ]
    },
    {
      "id": "q3s1",
      "section": "第（Ⅲ）问",
      "title": "第1步：由分段图形判断目标阶段",
      "t": 2,
      "derive": [
        ["∵", "t=0 时，重合部分是三角形，面积为 8√3/3＞2√3"],
        ["∵", "0＜t≤(8-4√3)/3 时，重合部分是四边形，面积继续增大"],
        ["∵", "(8-4√3)/3＜t＜4/3 时，重合部分是五边形，面积始终大于 2√3"],
        ["∵", "4/3≤t＜2 时，重合部分是四边形，面积递减到 2√3"],
        ["∵", "2≤t＜4 时，重合部分是三角形，面积从 2√3 递减到 0"],
        ["∴", "面积等于 2√3 只需在 2≤t＜4 的三角形阶段求"]
      ],
      "box": ["t=0：S=8√3/3＞2√3", "t<2：S＞2√3", "2≤t＜4：三角形阶段可取到 2√3"],
      "minis": [
        { "title": "t=0", "caption": "三角形，面积为 8√3/3。", "t": 0 },
        { "title": "四边形", "caption": "0＜t≤(8-4√3)/3，面积增大。", "t": 0.2 },
        { "title": "五边形", "caption": "(8-4√3)/3＜t＜4/3，面积仍大于 2√3。", "t": 1 },
        { "title": "四边形", "caption": "4/3≤t＜2，面积递减但仍大于 2√3。", "t": 1.6 },
        { "title": "三角形", "caption": "2≤t＜4，从 2√3 递减到 0。", "t": 2 }
      ]
    },
    {
      "id": "q3s2",
      "section": "第（Ⅲ）问",
      "title": "第2步：由三角形面积求 t",
      "t": 2,
      "derive": [
        ["∵", "后半段重合区域是直角三角形，竖直直角边为 4-t"],
        ["∵", "斜边方向与 x 轴夹角为 30°"],
        ["∴", "水平直角边为 √3(4-t)"],
        ["∴", "S=1/2·(4-t)·√3(4-t)=√3(4-t)^2/2"],
        ["∵", "S=2√3"],
        ["∴", "(4-t)^2=4"],
        ["∵", "0≤t≤4"],
        ["∴", "t=2"]
      ],
      "box": ["S=√3(4-t)^2/2", "t=2"]
    }
  ],
