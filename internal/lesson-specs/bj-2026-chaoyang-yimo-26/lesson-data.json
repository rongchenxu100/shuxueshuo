  "steps": [
    {
      "id": "i1s1",
      "section": "第（1）问",
      "title": "第1步：由系数求抛物线对称轴",
      "t": 1.5,
      "derive": [
        ["∵", "y＝ax²－a²x，且 a≠0"],
        ["∴", "二次项系数为 a，一次项系数为 −a²"],
        ["∴", "对称轴 x＝−(−a²)/(2a)"],
        ["∴", "x＝a/2"]
      ],
      "box": ["对称轴：x＝a/2"]
    },
    {
      "id": "q2s1",
      "section": "第（2）问",
      "title": "第1步：用 t 表示 x₁、x₂ 与 y₁、y₂",
      "t": 1.5,
      "derive": [
        ["设", "x₂＝t"],
        ["∵", "2＜x₂＜3"],
        ["∴", "2＜t＜3"],
        ["∵", "x₁＋x₂＝0"],
        ["∴", "x₁＝−t"],
        ["∵", "M、N 在 y＝ax²－a²x 上"],
        ["∴", "y₁＝a(−t)²－a²(−t)＝at²＋a²t＝at(t＋a)"],
        ["∴", "y₂＝at²－a²t＝at(t−a)"]
      ],
      "box": ["2＜t＜3", "y₁＝at(t＋a)", "y₂＝at(t−a)"]
    },
    {
      "id": "q2s2",
      "section": "第（2）问",
      "title": "第2步：先判断 y₁＞y₂",
      "t": 1.5,
      "derive": [
        ["∵", "y₁−y₂＝at(t＋a)−at(t−a)"],
        ["∴", "y₁−y₂＝2a²t"],
        ["∵", "a≠0，t＞2"],
        ["∴", "2a²t＞0"],
        ["∴", "y₁＞y₂ 恒成立"]
      ],
      "box": ["y₁−y₂＝2a²t＞0", "y₁＞y₂ 自动成立"]
    },
    {
      "id": "q2s3",
      "section": "第（2）问",
      "title": "第3步：由 y₁、y₂ 同号得到 |a|＜t",
      "t": 1.5,
      "derive": [
        ["∵", "y₁、y₂ 同号"],
        ["∴", "y₁y₂＞0"],
        ["∴", "at(t＋a)·at(t−a)＞0"],
        ["∴", "a²t²(t＋a)(t−a)＞0"],
        ["∵", "a²t²＞0"],
        ["∴", "(t＋a)(t−a)＞0"],
        ["∴", "t²−a²＞0"],
        ["∴", "|a|＜t"]
      ],
      "box": ["同号 ⇔ y₁y₂＞0", "|a|＜t"]
    },
    {
      "id": "q2s4",
      "section": "第（2）问",
      "title": "第4步：处理“对于所有 2＜t＜3”",
      "t": 1.5,
      "derive": [
        ["∵", "对所有 2＜t＜3，都要有 |a|＜t"],
        ["∴", "|a|≤2"],
        ["∵", "a≠0"],
        ["∴", "0＜|a|≤2"],
        ["∴", "−2≤a＜0 或 0＜a≤2"]
      ],
      "box": ["a∈[−2,0)∪(0,2]"]
    }
  ],
