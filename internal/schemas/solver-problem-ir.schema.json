{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "solver-problem-ir.schema.json",
  "title": "Method Solver ProblemIR Fixture",
  "type": "object",
  "required": ["meta", "input"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["problem_id", "title"],
      "additionalProperties": true,
      "properties": {
        "problem_id": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "input": {
      "type": "object",
      "required": ["problem_id", "pattern", "problem_type", "original_text", "symbols", "constraints", "data"],
      "additionalProperties": false,
      "properties": {
        "problem_id": { "type": "string" },
        "pattern": { "type": "string" },
        "problem_type": { "type": "string" },
        "original_text": {
          "type": "object",
          "required": ["source", "number", "lines"],
          "additionalProperties": false,
          "properties": {
            "source": { "type": "string" },
            "number": { "type": "string" },
            "lines": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          }
        },
        "symbols": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "symbol_roles": {
          "type": "object",
          "additionalProperties": {
            "enum": [
              "function_variable",
              "quadratic_coefficient",
              "dynamic_parameter"
            ]
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "data": {
          "type": "object",
          "required": ["function", "entities", "relations", "questions"],
          "additionalProperties": true,
          "properties": {
            "function": {
              "type": "object",
              "required": ["id", "type", "expression"],
              "additionalProperties": true,
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "expression": { "type": "string" },
                "coefficient_relation": { "type": "string" }
              }
            },
            "parameter": { "type": "string" },
            "path_problem": {
              "type": "object",
              "required": ["type", "scope", "path"],
              "additionalProperties": false,
              "properties": {
                "type": {
                  "enum": [
                    "two_moving_points_path_minimum",
                    "weighted_path_minimum"
                  ]
                },
                "scope": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 1 },
                "value": { "type": "string", "minLength": 1 }
              }
            },
            "entities": {
              "type": "object",
              "required": ["points"],
              "additionalProperties": true,
              "properties": {
                "points": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            },
            "relations": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type"],
                "additionalProperties": true,
                "properties": {
                  "type": { "type": "string" }
                }
              }
            },
            "questions": {
              "type": "array",
              "items": { "$ref": "#/$defs/question" },
              "minItems": 1
            }
          }
        }
      }
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "asks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "goals": {
          "type": "array",
          "items": { "$ref": "#/$defs/question_goal" }
        },
        "subquestions": {
          "type": "array",
          "items": { "$ref": "#/$defs/question" }
        }
      }
    },
    "question_goal": {
      "type": "object",
      "required": ["id", "answer_key", "target_path", "value_type", "required"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "answer_key": { "type": "string", "minLength": 1 },
        "target_path": { "type": "string", "pattern": "^\\$" },
        "value_type": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" }
      }
    }
  }
}
