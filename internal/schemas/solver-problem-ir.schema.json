{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "solver-problem-ir.schema.json",
  "title": "Method Solver ProblemIR Fixture",
  "type": "object",
  "required": ["meta", "input"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["problem_id", "title"],
      "additionalProperties": true,
      "properties": {
        "problem_id": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "input": {
      "type": "object",
      "required": [
        "problem_id",
        "pattern",
        "problem_type",
        "original_text",
        "scopes",
        "entities",
        "facts",
        "question_goals"
      ],
      "additionalProperties": false,
      "properties": {
        "problem_id": { "type": "string" },
        "pattern": { "type": "string" },
        "problem_type": { "type": "string" },
        "original_text": {
          "type": "object",
          "required": ["source", "number", "lines"],
          "additionalProperties": false,
          "properties": {
            "source": { "type": "string" },
            "number": { "type": "string" },
            "lines": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          }
        },
        "scopes": {
          "type": "array",
          "items": { "$ref": "#/$defs/canonical_scope" },
          "minItems": 1
        },
        "entities": {
          "type": "array",
          "items": { "$ref": "#/$defs/entity" },
          "minItems": 1
        },
        "facts": {
          "type": "array",
          "items": { "$ref": "#/$defs/fact" },
          "minItems": 1
        },
        "question_goals": {
          "type": "array",
          "items": { "$ref": "#/$defs/canonical_question_goal" },
          "minItems": 1
        }
      }
    }
  },
  "$defs": {
    "canonical_scope": {
      "type": "object",
      "required": ["scope_id", "label", "parent"],
      "additionalProperties": true,
      "properties": {
        "scope_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "parent": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "asks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "canonical_question_goal": {
      "type": "object",
      "required": ["handle", "scope_id", "answer_key", "value_type", "required", "description"],
      "additionalProperties": true,
      "properties": {
        "handle": { "type": "string", "pattern": "^answer:[A-Za-z0-9_.]+$" },
        "scope_id": { "type": "string", "minLength": 1 },
        "answer_key": { "type": "string", "minLength": 1 },
        "value_type": { "type": "string", "minLength": 1 },
        "target_handle": { "type": "string", "minLength": 1 },
        "valid_scope": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "entity": {
      "type": "object",
      "required": ["handle", "entity_type", "name", "scope_id", "description"],
      "additionalProperties": true,
      "properties": {
        "handle": {
          "type": "string",
          "pattern": "^(point|line|segment|ray|function|symbol|angle|circle|polygon):[A-Za-z0-9_]+:[A-Za-z0-9_]+$"
        },
        "entity_type": {
          "enum": [
            "point",
            "line",
            "segment",
            "ray",
            "function",
            "symbol",
            "angle",
            "circle",
            "polygon"
          ]
        },
        "name": { "type": "string", "minLength": 1 },
        "scope_id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "fact": {
      "type": "object",
      "required": ["handle", "type", "scope_id", "valid_scope", "description"],
      "additionalProperties": true,
      "properties": {
        "handle": {
          "type": "string",
          "pattern": "^fact:[A-Za-z0-9_]+:[A-Za-z0-9_]+$"
        },
        "type": { "type": "string", "minLength": 1 },
        "scope_id": { "type": "string", "minLength": 1 },
        "valid_scope": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    }
  }
}
