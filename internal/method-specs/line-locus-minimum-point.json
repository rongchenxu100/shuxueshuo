      "type": "Point",
      "required": true
    },
    "minimum_point_2": {
      "type": "Point",
      "required": true
    },
    "target": {
      "type": "PointRef",
      "required": true
    },
    "parameter": {
      "type": "Symbol",
      "required": false
    },
    "parameter_value": {
      "type": "ParameterValue",
      "required": false
    }
  },
  "outputs": {
    "point": "Point"
  },
