{
  "method_id": "distance_between_points",
  "title": "计算两点距离",
  "description": "计算两点距离，并可选代入参数值得到具体距离。",
  "summary": "输入两点及可选参数值，输出两点距离。端点仍含未定参数时结果是开放表达式；所有参数已确定时结果是可直接使用的闭合值。代入一个参数不保证其他参数也已闭合。",
  "solves": [
    "derive_distance_between_points"
  ],
  "inputs": {
    "p1": {
      "type": "Point",
      "required": true
    },
    "p2": {
      "type": "Point",
      "required": true
    },
    "parameter": {
      "type": "Symbol",
      "required": false
    },
    "parameter_value": {
      "type": "ParameterValue",
      "required": false
    }
  },
  "outputs": {
    "distance": "MinimumExpression",
    "evaluated_distance": "MinimumExpression"
  },
  "is_pure": true,
  "scalar_result_forms": {
    "distance": {
      "possible_forms": [
        "open_expression",
        "closed_value"
      ],
      "description": "端点仍含未确定参数时为 open_expression；不存在自由参数时为 closed_value，可直接作为数值答案。",
      "closure_policy": "no_free_symbols"
    },
    "evaluated_distance": {
      "possible_forms": [
        "open_expression",
        "closed_value"
      ],
      "description": "代入指定参数后若仍含其他未确定参数则为 open_expression；不存在自由参数时为 closed_value。",
      "closure_policy": "no_free_symbols"
    }
  },
  "explanation": {
    "role_schema": {
      "p1": "第一个点或线段端点。",
      "p2": "第二个点或线段端点。",
      "distance": "两点距离表达式。"
    },
    "student_goal_template": "计算 {p1} 与 {p2} 的距离，作为当前路径最值表达式。",
    "student_title_template": "",
    "student_title_templates_by_goal": {},
    "derive_templates": [
      "由距离公式，{p1}{p2} = {distance}。",
      "化简得到当前需要的距离或最小值表达式。"
    ],
    "box_templates": [
      "{p1}{p2} = {distance}"
    ],
    "explanation_level": "template",
    "role_binding_strategy": "role_name_registry",
    "role_binder_id": "distance_between_points"
  }
}
