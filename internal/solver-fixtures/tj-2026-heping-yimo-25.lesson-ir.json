      ],
      "title": "第3步：将军饮马得到最小值表达式",
      "nav_title": "将军饮马取最小值",
      "goal": "计算 OG 的长度作为最小值",
      "derive": [
        [
          "∵",
          "由上一步，OM+BN=OM+MG"
        ],
        [
          "∵",
          "M 在线段 BC 上运动，G 是固定点"
        ],
        [
          "∴",
          "当 O、M、G 共线时，OM+MG 取得最小值 OG"
        ],
        [
          "∵",
          "G 在射线 CD 上，且 CG=CB"
        ],
        [
          "∴",
          "G(3√(a²+1)/|a|,-3)"
        ],
        [
          "∴",
          "OG=√((3√(a²+1)/|a|)²+(-3)²)=3√(2a²+1)/|a|"
        ]
      ],
      "box": [
        "G(3√(a²+1)/|a|,-3)",
        "最小值为 3√(2a²+1)/|a|"
      ],
      "gaps": [],
