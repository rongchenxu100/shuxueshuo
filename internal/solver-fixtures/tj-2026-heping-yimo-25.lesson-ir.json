      ],
      "title": "第4步：由最小值等于 √34，解出 a 的值",
      "nav_title": "由最小值求a",
      "goal": "求出 a",
      "derive": [
        [
          "∵",
          "题设给出 OM+BN 的最小值为 √34，且最小值表达式为 3√(2a²+1)/|a|"
        ],
        [
          "∴",
          "3√(2a²+1)/|a|=√34"
        ],
        [
          "∵",
          "a>0"
        ],
        [
          "∴",
          "|a|=a"
        ],
        [
          "∴",
          "两边平方得 9(2a²+1)=34a²"
        ],
        [
          "∴",
          "16a²=9，a²=9/16"
        ],
        [
          "∵",
          "a>0"
        ],
        [
          "∴",
          "a=3/4"
        ]
      ],
      "box": [
