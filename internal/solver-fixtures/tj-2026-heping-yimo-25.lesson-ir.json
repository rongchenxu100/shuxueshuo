      "title": "第2步：构造全等三角形，把两动点问题转化为单动点问题",
      "nav_title": "两动点转化单动点",
      "goal": "把两动点路径降维",
      "derive": [
        [
          "作",
          "在射线 CD 上构造点 G，使 CG=CB"
        ],
        [
          "∵",
          "B、C、M 共线，N、C、G 共线，且 CN=CM"
        ],
        [
          "∴",
          "△BCN≌△GCM（SAS）"
        ],
        [
          "∴",
          "BN=MG"
        ],
        [
          "∴",
          "OM+BN=OM+MG"
        ]
      ],
      "box": [
