        "trace:derive_D_coordinate:0:translated_point",
        "trace:derive_i_1_parabola:0:quadratic_from_constraints"
      ],
      "title": "第1步：求 C、D 点坐标，代入求函数解析式",
      "nav_title": "代入已知点求解析式",
      "goal": "确定第（Ⅰ）问的抛物线",
      "derive": [
        [
          "∵",
          "抛物线与 y 轴交于点 C，令 x=0 得 y=-3"
        ],
        [
          "∴",
          "C(0,-3)"
        ],
        [
          "∵",
          "点 D 是 C 向右平移 2 个单位得到的"
        ],
        [
          "∴",
          "D(2,-3)"
        ],
        [
          "∵",
          "点 A(-1,0) 和 D(2,-3) 都在抛物线上"
        ],
        [
          "∴",
          "代入 y=ax²+bx-3 得方程组"
        ],
        [
          "∴",
          "a·(-1)²+b·(-1)-3=0，4a+2b-3=-3"
        ],
        [
          "∴",
          "a=1，b=-2"
        ],
        [
          "∴",
          "y=x²-2x-3"
        ]
      ],
      "box": [
        "C(0,-3)",
        "D(2,-3)",
        "y=x²-2x-3"
      ],
      "gaps": [],
      "teaching_substep_ids": []
    },
    {
      "id": "step_2",
      "scope_id": "i_2",
      "source_step_ids": [
        "derive_i_B_coordinate",
        "derive_i_2_equal_angle"
      ],
      "capability_ids": [
        "quadratic_x_axis_intercept_point",
        "angle_sum_equal_angle_candidates"
      ],
      "trace_refs": [
        "trace:derive_i_B_coordinate:0:quadratic_x_axis_intercept_point",
        "trace:derive_i_2_equal_angle:0:angle_sum_equal_angle_candidates"
      ],
      "title": "第2步：求 B 坐标，并利用 45° 条件推出等角关系",
      "nav_title": "求B并推出等角",
      "goal": "找到与 ∠ACO 相等的角",
      "derive": [
        [
          "∵",
          "抛物线 y=x²-2x-3，令 y=0 得 x²-2x-3=0"
        ],
        [
          "∴",
          "解得 x₁=-1（点 A），x₂=3"
        ],
        [
          "∴",
          "B(3,0)"
        ],
        [
          "∵",
          "C(0,-3)，B(3,0)"
        ],
        [
          "∴",
          "∠CBO=45°（△CBO 是等腰直角三角形）"
        ],
        [
          "∵",
          "∠CBE+∠ACO=45°"
        ],
        [
          "∴",
          "∠CBE+∠ACO=∠CBO，即 ∠ACO=∠OBE"
        ]
      ],
      "box": [
        "∠OBE=∠ACO"
      ],
      "gaps": [],
      "teaching_substep_ids": []
    },
    {
      "id": "step_3",
      "scope_id": "i_2",
      "source_step_ids": [
        "derive_i_2_F_coordinate"
      ],
      "capability_ids": [
        "axis_intercept_from_equal_acute_angles"
      ],
      "trace_refs": [
        "trace:derive_i_2_F_coordinate:0:axis_intercept_from_equal_acute_angles"
      ],
      "title": "第3步：由等角关系确定直线 BE 与 y 轴的交点 F",
      "nav_title": "由等角求F",
      "goal": "找到 F 的坐标，为求直线 BE 做准备",
      "derive": [
        [
          "∵",
          "∠OBE=∠ACO，且 ∠AOC=90°，∠BOF=90°"
        ],
        [
          "∴",
          "在 Rt△AOC 中，tan∠ACO=AO/CO=1/3；在 Rt△BOF 中，tan∠OBE=OF/OB=OF/3"
        ],
        [
          "∵",
          "∠OBE=∠ACO"
        ],
        [
          "∴",
          "tan 值相等，OF/3=1/3，得 OF=1"
        ],
        [
          "∵",
          "F 在 y 轴负半轴上"
        ],
        [
          "∴",
          "F(0,-1)"
        ]
      ],
      "box": [
        "F(0,-1)"
      ],
      "gaps": [],
      "teaching_substep_ids": []
    },
    {
      "id": "step_4",
      "scope_id": "i_2",
      "source_step_ids": [
        "derive_i_2_E_coordinate"
      ],
      "capability_ids": [
        "line_parabola_second_intersection_point"
      ],
      "trace_refs": [
        "trace:derive_i_2_E_coordinate:0:line_parabola_second_intersection_point"
      ],
      "title": "第4步：联立直线与抛物线求点 E",
      "nav_title": "联立求E",
      "goal": "求出满足条件的 E 的坐标",
      "derive": [
        [
          "∵",
          "直线 BE 过 B(3,0) 和 F(0,-1)"
        ],
        [
          "∴",
          "BE: y=(1/3)x-1"
        ],
        [
          "∵",
          "E 是直线 BE 与抛物线 y=x²-2x-3 的交点（除 B 外）"
        ],
        [
          "∴",
          "联立 (1/3)x-1=x²-2x-3"
        ],
        [
          "∴",
          "整理得 3x²-7x-6=0，解得 x=3（点 B）或 x=-2/3"
        ],
        [
          "∵",
          "点 E 的横坐标 m 满足 -1<m<0"
        ],
        [
          "∴",
          "取 x=-2/3，E(-2/3,-11/9)"
        ]
      ],
      "box": [
        "BE: y=(1/3)x-1",
        "E(-2/3,-11/9)"
      ],
      "gaps": [],
      "teaching_substep_ids": []
    },
    {
      "id": "step_5",
      "scope_id": "ii",
      "source_step_ids": [
